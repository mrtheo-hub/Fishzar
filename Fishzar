local FTab = Window:Tab({Title = "Fishing", Icon = "solar:fishing-rod-bold"})
local UTab = Window:Tab({Title = "Utilities", Icon = "solar:shield-keyhole-bold"})
local ITab = Window:Tab({Title = "Integration", Icon = "solar:settings-bold"})

-- [TAB MAIN - COPYRIGHT]
MainTab:Section({Title = "© 2026 DapzX Team. All Rights Reserved."})
MainTab:Section({Title = "Hak Cipta: Kode privat dilindungi hukum."})
MainTab:Button({Title = "Copy Discord", Callback = function() setclipboard("https://discord.gg/getsades") end})

-- [TAB FISHING - LOGIKA MANCING YANG ASLI (LOCKED)]
FTab:Toggle({Title = "Auto Farm", Callback = function(s) _G.Config.Farming = s end})
FTab:Input({Title = "Delay", Placeholder = "3.0", Callback = function(v) _G.Config.Delay = tonumber(v) or 3 end})

task.spawn(function()
    while true do
        task.wait(0.5)
        if _G.Config.Farming and LocalPlayer.Character then
            pcall(function()
                local tool = LocalPlayer.Character:FindFirstChildWhichIsA("Tool")
                if tool then
                    local root = LocalPlayer.Character.HumanoidRootPart
                    local castPos = root.Position + (root.CFrame.LookVector * 15) + Vector3.new(0, -6, 0)
                    AnimController:Play("PrepareCast", 0.1)
                    FishingSystem.CastReplication:FireServer(castPos, root.Position, tool.Name, 99.5)
                    task.wait(1.5)
                    FishingSystem.PrecalcFish:InvokeServer()
                    task.wait(0.5)
                    FishingSystem.ReplicatePullAlert:FireServer("rbxassetid://76503247176490")
                    task.wait(_G.Config.Delay)
                    FishingSystem.FishGiver:FireServer({ ["hookPosition"] = castPos })
                    task.wait(0.3)
                    FishingSystem.CleanupCast:FireServer()
                    AnimController:Play("EquippedAnimation", 0.3)
                    task.wait(1.5)
                end
            end)
        end
    end
end)

-- [TAB UTILITIES]
UTab:Toggle({Title = "Streamer Mode", Callback = function(s) _G.Config.Streamer = s end})
local PingL = UTab:Section({Title = "Ping: Loading..."})

-- [TAB INTEGRATION]
ITab:Input({Title = "Webhook URL", Callback = function(v) _G.Config.Webhook = v end})

-- [HEARTBEAT UTILITIES]
RunService.Heartbeat:Connect(function()
    if PingL then PingL:SetTitle("Ping: " .. math.floor(Stats.Network.ServerStatsItem["Data Ping"]:GetValue()) .. "ms") end
    if _G.Config.Streamer then
        for _, p in pairs(Players:GetPlayers()) do
            if p.Character and p.Character:FindFirstChild("Head") then
                for _, v in pairs(p.Character.Head:GetChildren()) do if v:IsA("BillboardGui") then v.Enabled = false end end
            end
        end
    end
end)

