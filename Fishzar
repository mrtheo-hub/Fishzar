-- Fungsi Webhook Discord (Mengikuti format gambar referensi)
local function SendWebhook(fishData)
    if _G.WebhookURL == "" or not request then return end
    if not _G.WebhookFilters[fishData.rarity] then return end

    local embed = {
        ["title"] = LocalPlayer.Name .. " New Fish Caught !",
        ["color"] = tonumber("0x9D4EDD"),
        ["fields"] = {
            {["name"] = "🐟 Fish Name", ["value"] = fishData.name or "Unknown", ["inline"] = false},
            {["name"] = "⭐ Rarity", ["value"] = fishData.rarity or "Unknown", ["inline"] = false},
            {["name"] = "⚖️ Weight", ["value"] = tostring(fishData.weight) .. "kg", ["inline"] = false},
            {["name"] = "🧬 Mutation", ["value"] = fishData.mutation or "None", ["inline"] = false},
            {["name"] = "💵 Sell Price", ["value"] = "$" .. tostring(fishData.price or 0), ["inline"] = false},
            {["name"] = "👤 Account Name", ["value"] = LocalPlayer.Name, ["inline"] = false}
        }
    }
    
    local msg = { ["embeds"] = {embed} }
    pcall(function()
        request({
            Url = _G.WebhookURL,
            Method = "POST",
            Headers = {["Content-Type"] = "application/json"},
            Body = HttpService:JSONEncode(msg)
        })
    end)
end

