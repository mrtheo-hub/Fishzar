RunService.RenderStepped:Connect(function()
    if _G.WalkOnWater and LocalPlayer.Character then
        local p = LocalPlayer.Character.HumanoidRootPart.Position
        if not workspace:FindFirstChild("WaterPart") then local part = Instance.new("Part", workspace); part.Name = "WaterPart"; part.Anchored = true; part.Transparency = 1; part.Size = Vector3.new(1000, 1, 1000) end
        workspace.WaterPart.Position = Vector3.new(p.X, 4.5, p.Z)
    elseif workspace:FindFirstChild("WaterPart") then workspace.WaterPart:Destroy() end
