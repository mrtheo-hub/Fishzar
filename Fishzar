LocalPlayer.Backpack.ChildAdded:Connect(function(item)
    if item:IsA("Tool") and not item.Name:lower():find("rod") then
        task.spawn(function()
            task.wait(1)
            local rar = item:GetAttribute("Rarity") or item:GetAttribute("rarity") or "Common"
            if FlowConfig.WebhookFilters[rar] and FlowConfig.WebhookURL ~= "" then
                local data = {
                    ["embeds"] = {{
                        ["title"] = "🎣 Flow Hub | New Catch!", ["color"] = 0x00B4D8,
                        ["fields"] = {
                            {["name"] = "Fish", ["value"] = item.Name, ["inline"] = true},
                            {["name"] = "Rarity", ["value"] = rar, ["inline"] = true}
                        }, ["footer"] = {["text"] = "Flow Hub v1.2.5"}
                    }}
                }
                pcall(function() request({Url = FlowConfig.WebhookURL, Method = "POST", Headers = {["Content-Type"] = "application/json"}, Body = HttpService:JSONEncode(data)}) end)
            end
        end)
    end
end)

getgenv().FlowConnection = RunService.Heartbeat:Connect(function()
    local char = LocalPlayer.Character
    if char and char:FindFirstChild("HumanoidRootPart") then
        local root = char.HumanoidRootPart
        if FlowConfig.WalkWater and lockedY then
            waterPart.CFrame = CFrame.new(root.Position.X, lockedY, root.Position.Z)
        else waterPart.CFrame = CFrame.new(0, -9999, 0) end
    end
end)

task.spawn(function()
    local CachedSell = nil
    while task.wait(1) do
        local char = LocalPlayer.Character
        if not char then continue end
        local hum = char:FindFirstChild("Humanoid")
        
        if FlowConfig.AntiDrown and hum then
            hum:SetStateEnabled(Enum.HumanoidStateType.Swimming, false)
            for _, v in pairs(char:GetDescendants()) do
                if (v.Name:lower() == "oxygen" or v.Name:lower() == "o2") and (v:IsA("NumberValue") or v:IsA("IntValue")) then v.Value = 100 end
            end
        elseif hum then hum:SetStateEnabled(Enum.HumanoidStateType.Swimming, true) end

        if FlowConfig.AutoEquip and not char:FindFirstChildWhichIsA("Tool") then
            for _, item in pairs(LocalPlayer.Backpack:GetChildren()) do
                if item:IsA("Tool") and (item.Name:lower():find("rod") or item.Name:lower():find("kail")) and not item:GetAttribute("Rarity") then
                    hum:EquipTool(item)
                    break
                end
            end
        end

        if FlowConfig.AutoSell then
            if not CachedSell then CachedSell = ReplicatedStorage:FindFirstChild("SellFish", true) end
            if CachedSell then pcall(function() CachedSell:InvokeServer() end) end
        end

        if FlowConfig.Streamer then
            for _, p in pairs(Players:GetPlayers()) do
                if p.Character then
                    for _, v in pairs(p.Character:GetDescendants()) do
                        if v:IsA("BillboardGui") then v.Enabled = false end
                        if v:IsA("TextLabel") and (v.Name:lower():find("name") or v.Name:lower():find("label")) then v.Visible = false end
                    end
                end
            end
        end
    end
end)

task.spawn(function()
    while task.wait(0.5) do
        if FlowConfig.Farming and LocalPlayer.Character and FishingSystem then
            pcall(function()
                local tool = LocalPlayer.Character:FindFirstChildWhichIsA("Tool")
                if tool and (tool.Name:lower():find("rod") or tool.Name:lower():find("kail")) then
                    local root = LocalPlayer.Character.HumanoidRootPart
                    local castPos = root.Position + (root.CFrame.LookVector * 15)
                    if AnimController then AnimController:Play("PrepareCast", 0.1) end
                    FishingSystem.CastReplication:FireServer(castPos, root.Position, tool.Name, 99.5)
                    task.wait(1.5); FishingSystem.PrecalcFish:InvokeServer(); task.wait(0.5)
                    FishingSystem.ReplicatePullAlert:FireServer("rbxassetid://76503247176490")
                    task.wait(FlowConfig.Delay)
                    FishingSystem.FishGiver:FireServer({["hookPosition"]=castPos})
                    task.wait(1.5); FishingSystem.CleanupCast:FireServer()
                end
            end)
        end
    end
end)
