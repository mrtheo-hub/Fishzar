-- FISHING LOOP (DIPERBAIKI)
task.spawn(function()
    local FishingSystem = ReplicatedStorage:WaitForChild("FishingSystem")
    while true do
        task.wait(0.5)
        if _G.FarmingActive and LocalPlayer.Character then
            local tool = LocalPlayer.Character:FindFirstChildWhichIsA("Tool")
            local root = LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
            
            if tool and root then
                local castPos = root.Position + (root.CFrame.LookVector * 15)
                
                -- STEP 1: Cast
                FishingSystem.CastReplication:FireServer(castPos, root.Position, tool.Name, 99.5)
                task.wait(_G.MinigameDelay)
                
                -- STEP 2: Tarik (Giver)
                FishingSystem.FishGiver:FireServer({["hookPosition"] = castPos})
                
                -- STEP 3: Notif Webhook & Cleanup
                task.wait(0.5)
                for _, item in pairs(LocalPlayer.Backpack:GetChildren()) do
                    if item:IsA("Tool") and item:GetAttribute("rarity") and _G.FilterRarity[item:GetAttribute("rarity")] then
                        SendWebhook({
                            fishId = item:GetAttribute("fishId") or item.Name,
                            rarity = item:GetAttribute("rarity"),
                            weight = item:GetAttribute("weight") or 0
                        }, false)
                    end
                end
                
                FishingSystem.CleanupCast:FireServer()
                task.wait(2) -- Jeda antar tarikan agar server tidak lag
            end
        end
    end
end)

-- AUTO SELL LOOP (SIMPLE & KERJA)
task.spawn(function()
    while true do
        task.wait(10) -- Cek tiap 10 detik
        if _G.AutoSellActive then
            local fs = ReplicatedStorage:FindFirstChild("FishingSystem")
            local sellEvent = fs and fs:FindFirstChild("SellFish")
            if sellEvent then
                local items = {}
                for _, i in pairs(LocalPlayer.Backpack:GetChildren()) do
                    if i:IsA("Tool") and i:GetAttribute("rarity") then 
                        table.insert(items, i) 
                    end
                end
                if #items > 0 then 
                    sellEvent:FireServer("SellAllBatch", items)
                end
            end
        end
    end
end)
