-- ============================================================================
-- CONFIG
-- ============================================================================
_G.FarmingActive = false
_G.CatchDelay = 1.0

-- ============================================================================
-- THE SCANNER (Mencari Remote Tanpa Nama)
-- ============================================================================
local function GetRemotes()
    local folder = ReplicatedStorage:FindFirstChild("FishingSystem")
    if not folder then return nil end
    
    local found = {}
    for _, v in pairs(folder:GetChildren()) do
        if v:IsA("RemoteEvent") or v:IsA("RemoteFunction") then
            local name = v.Name:lower()
            if name:find("cast") or name:find("line") or name:find("throw") then
                found.Cast = v
            elseif name:find("give") or name:find("catch") or name:find("claim") or name:find("reward") then
                found.Catch = v
            elseif name:find("win") or name:find("finish") or name:find("result") or name:find("success") then
                found.Win = v
            end
        end
    end
    return found
end

