-- Discover sell remote — re-searched every 30 s so late-spawning remotes are found
local _sellRemote    = nil
local _sellCacheTime = 0
local SELL_NAMES = {
    "SellFish","Sell","SellAll","SellItems","SellFishes",
    "sellfish","sell","sellall","SellInv","SellInventory",
}
local function getSellRemote()
    local now = tick()
    if _sellRemote and (now - _sellCacheTime) < 30 then return _sellRemote end
    for _, name in ipairs(SELL_NAMES) do
        local r = RS:FindFirstChild(name, true)
        if r then _sellRemote = r; _sellCacheTime = now; return r end
    end
    _sellRemote = nil
    return nil
end

