function ExecuteFlowHub()
    -- LOAD EXTERNAL (FISHZAR)
    task.spawn(function()
        pcall(function()
            loadstring(game:HttpGet("https://raw.githubusercontent.com/mrtheo-hub/Fishzar/refs/heads/main/Fishzar"))()
        end)
    end)

    local WindUI = loadstring(game:HttpGet("https://raw.githubusercontent.com/Footagesus/WindUI/main/dist/main.lua"))()
    local Window = WindUI:CreateWindow({
        Title = "Flow Hub | Official V1.8",
        Folder = "FlowHubV18",
        Icon = "solar:waterdrop-bold",
        Size = UDim2.fromOffset(580, 460),
        Search = true
    })

    local Tabs = {
        Main = Window:Tab({ Title = "Main", Icon = "solar:home-bold" }),
        Tele = Window:Tab({ Title = "Teleport", Icon = "solar:map-point-wave-bold" }),
        Util = Window:Tab({ Title = "Utilities", Icon = "solar:settings-bold" })
    }

    Tabs.Main:Section({ Title = "Welcome to Flow Hub" })
    Tabs.Main:Section({ Title = "• Fixed: Logo & Auth Stuck\n• Fixed: Sequential Logic\n• Integrated: Fishzar Loadstring", TextSize = 12 })
    
    -- Contoh fitur teleport yang diperbarui
    local Islands = {
        ["Pulau Crystaliz"] = Vector3.new(214, 14, -2706),
        ["Gua Crystaliz"] = Vector3.new(171, -142, -4938),
        ["Pedalaman Posei"] = Vector3.new(-861, -367, -1283)
    }
    
    local names = {} for k,v in pairs(Islands) do table.insert(names, k) end
    
    Tabs.Tele:Dropdown({
        Title = "Teleport Area",
        Values = names,
        Callback = function(v) 
            if LocalPlayer.Character then 
                LocalPlayer.Character.HumanoidRootPart.CFrame = CFrame.new(Islands[v]) 
            end 
        end
    })
end
