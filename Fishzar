local Stats = game:GetService("Stats")
local FishingSystem = ReplicatedStorage:WaitForChild("FishingSystem")
local AnimController = require(FishingSystem.FishingModules:WaitForChild("AnimationController"))

_G.Config = {Farming = false, Delay = 3, Webhook = "", WalkWater = false, Drown = false, Streamer = false, AntiStaff = false}
_G.RarityFilter = {["Legendary"]=true, ["Epic"]=true, ["Rare"]=true, ["Uncommon"]=true, ["Common"]=true}

-- [[ 1. UI SETUP ]]
local WindUI = loadstring(game:HttpGet("https://raw.githubusercontent.com/Footagesus/WindUI/main/dist/main.lua"))()
local Window = WindUI:CreateWindow({Title = "DapzX Atomic | Fishzar v20", Icon = "solar:atom-bold", Size = UDim2.fromOffset(580, 460), OpenButton = {Enabled = true, Title = "Open"}})

-- TABS (Dibuat di awal agar tidak hilang)
