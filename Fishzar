local _casting      = false  -- debounce: prevents overlapping casts on pcall early-exit
local _sessionCaught = 0     -- session fish counter

task.spawn(function()
    while task.wait(0.5) do
        if not C.Farming  then continue end
        if not FS         then continue end
        if _casting       then continue end  -- previous cast still running

        local char = LP.Character; if not char then continue end
        local hum  = char:FindFirstChildOfClass("Humanoid")
        if not hum or hum.Health <= 0 then continue end

        local tool = getEquippedRod()
        if not tool then continue end

        local root = char:FindFirstChild("HumanoidRootPart")
        if not root then continue end

        _casting = true
        pcall(function()
            local castPos = root.Position + root.CFrame.LookVector * 15

            if Anim then pcall(function() Anim:Play("PrepareCast", 0.1) end) end

            local r1 = getR("CastReplication")
            if r1 then r1:FireServer(castPos, root.Position, tool.Name, 99.5) end
            task.wait(1.5)

            local r2 = getR("PrecalcFish")
            if r2 then pcall(function() r2:InvokeServer() end) end
            task.wait(0.5)

            local r3 = getR("ReplicatePullAlert")
            if r3 then r3:FireServer("rbxassetid://76503247176490") end
            task.wait(math.max(C.Delay, 0.5))

            local r4 = getR("FishGiver")
            if r4 then
                r4:FireServer({ hookPosition = castPos })
                _sessionCaught += 1
            end
            task.wait(1.0)

            local r5 = getR("CleanupCast")
            if r5 then r5:FireServer() end
        end)
        _casting = false
    end
end)

