--  [14] 1-SECOND LOOP — Anti Drown, AutoEquip, AutoSell, Streamer
-- ═══════════════════════════════════════════
task.spawn(function()
    while task.wait(1) do
        local char = LocalPlayer.Character
        if not char then continue end
        local hum = char:FindFirstChildOfClass("Humanoid")

        -- ── AUTO SELL ──
        if FlowConfig.AutoSell then
            pcall(function()
                -- Try common remote names
                local sellRemote = ReplicatedStorage:FindFirstChild("SellFish", true)
                               or ReplicatedStorage:FindFirstChild("Sell", true)
                               or ReplicatedStorage:FindFirstChild("SellAll", true)
                               or ReplicatedStorage:FindFirstChild("SellItems", true)
                if not sellRemote then return end

                local mode = FlowConfig.SellRemoteMode
                if mode == "invoke" or (mode == "auto" and sellRemote:IsA("RemoteFunction")) then
                    pcall(function() sellRemote:InvokeServer() end)
                elseif mode == "fire" or (mode == "auto" and sellRemote:IsA("RemoteEvent")) then
                    pcall(function() sellRemote:FireServer() end)
                end
            end)
        end

        -- ── ANTI DROWN ──
        if FlowConfig.AntiDrown and hum then
            pcall(function()
                hum:SetStateEnabled(Enum.HumanoidStateType.Swimming, false)
                for _, v in pairs(char:GetDescendants()) do
                    if v:IsA("NumberValue") or v:IsA("IntValue") then
                        local vn = v.Name:lower()
                        if vn == "oxygen" or vn == "o2" or vn == "air" then
                            v.Value = 100
                        end
                    end
                end
            end)
        elseif hum then
            pcall(function()
                hum:SetStateEnabled(Enum.HumanoidStateType.Swimming, true)
            end)
        end

        -- ── AUTO EQUIP ROD ──
        if FlowConfig.AutoEquip and hum and not char:FindFirstChildWhichIsA("Tool") then
            for _, item in pairs(LocalPlayer.Backpack:GetChildren()) do
                if item:IsA("Tool") then
                    local iName = item.Name:lower()
                    if iName:find("rod") or iName:find("kail") or iName:find("fishing") then
                        pcall(function() hum:EquipTool(item) end)
                        break
                    end
                end
            end
        end

        -- ── STREAMER MODE ──
        if FlowConfig.Streamer then
            for _, p in pairs(Players:GetPlayers()) do
                if p.Character then
                    for _, v in pairs(p.Character:GetDescendants()) do
                        pcall(function()
                            if v:IsA("BillboardGui") then
                                v.Enabled = false
                            elseif v:IsA("TextLabel") then
                                local vn = v.Name:lower()
                                if vn:find("name") or vn:find("label") or vn:find("overhead") then
                                    v.Visible = false
                                end
                            end
                        end)
                    end
                end
            end
        end

    end -- while
end)

-- ═══════════════════════════════════════════
--  [15] FARMING LOOP
-- ═══════════════════════════════════════════
-- Runs every 0.5s but only acts when Farming is true and all conditions pass
task.spawn(function()
    while task.wait(0.5) do
        -- Guard checks (fast-fail, no pcall overhead)
        if not FlowConfig.Farming then continue end
        if not FishingSystem         then continue end

        local char = LocalPlayer.Character
        if not char then continue end

        local hum = char:FindFirstChildOfClass("Humanoid")
        if not hum or hum.Health <= 0 then continue end

        local tool = char:FindFirstChildWhichIsA("Tool")
        if not tool then continue end

        local tName = tool.Name:lower()
        if not (tName:find("rod") or tName:find("kail") or tName:find("fishing")) then continue end

        local root = char:FindFirstChild("HumanoidRootPart")
        if not root then continue end

        -- All checks passed — do the cast
        pcall(function()
            local castPos = root.Position + (root.CFrame.LookVector * 15)

            -- Optional animation (safe)
            if AnimController then
                pcall(function() AnimController:Play("PrepareCast", 0.1) end)
            end

            -- 1. Cast
            local castRemote = getRemote("CastReplication")
            if castRemote then
                castRemote:FireServer(castPos, root.Position, tool.Name, 99.5)
            end

            task.wait(1.5)

            -- 2. Pre-calculate fish type
            local precalcRemote = getRemote("PrecalcFish")
            if precalcRemote then
                pcall(function() precalcRemote:InvokeServer() end)
            end

            task.wait(0.5)

            -- 3. Send pull alert (triggers bite animation server-side)
            local pullRemote = getRemote("ReplicatePullAlert")
            if pullRemote then
                pullRemote:FireServer("rbxassetid://76503247176490")
            end

            -- 4. Wait user-configured delay
            task.wait(math.max(FlowConfig.Delay, 1))

            -- 5. Claim the fish
            local giverRemote = getRemote("FishGiver")
            if giverRemote then
                giverRemote:FireServer({ hookPosition = castPos })
            end

            task.wait(1.0)

            -- 6. Cleanup so server resets for next cast
            local cleanupRemote = getRemote("CleanupCast")
            if cleanupRemote then
                cleanupRemote:FireServer()
            end
        end)

    end -- while
end)

