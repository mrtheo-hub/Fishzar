-- [[ SERVICES ]]
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local HttpService = game:GetService("HttpService")
local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer

-- [[ CONFIG ]]
_G.FarmingActive = false
_G.AutoSellActive = false
_G.WebhookURL = ""
_G.MinigameDelay = 3.0

-- [[ LOAD LIBRARY ]]
local WindUI
local success, result = pcall(function()
    return loadstring(game:HttpGet("https://raw.githubusercontent.com/Footagesus/WindUI/main/dist/main.lua"))()
end)

if success and result then
    WindUI = result
else
    warn("WindUI Gagal Dimuat: " .. tostring(result))
    return -- Berhenti jika library tidak bisa dimuat
end

-- [[ UI INITIALIZATION ]]
local Window = WindUI:CreateWindow({
    Title = "DapzX Atomic | Flow Hub",
    Author = "Theodore",
    Folder = "dapzxatomic",
    Icon = "solar:atom-bold",
    Size = UDim2.fromOffset(580, 460)
})

-- [[ FUNGSI WEBHOOK ]]
local function SendWebhook(msg)
    if _G.WebhookURL == "" or not _G.WebhookURL:find("discord") then return end
    pcall(function()
        (http_request or request or syn.request)({
            Url = _G.WebhookURL,
            Method = "POST",
            Headers = {["Content-Type"] = "application/json"},
            Body = HttpService:JSONEncode({["content"] = msg})
        })
    end)
end

-- [[ TAB: FISHING ]]
local FishingTab = Window:Tab({Title = "Fishing", Icon = "solar:cursor-square-bold"})
FishingTab:Section({Title = "Auto Farm"}):Toggle({Title = "Enable Auto Farm", Callback = function(s) _G.FarmingActive = s end})
FishingTab:Section({Title = "Settings"}):Slider({Title = "Delay (Detik)", Value = {Min = 0.5, Max = 5, Default = 3}, Callback = function(v) _G.MinigameDelay = v end})

-- [[ TAB: SHOP ]]
local ShopTab = Window:Tab({Title = "Shop", Icon = "solar:bag-check-bold"})
ShopTab:Section({Title = "Auto Sell"}):Toggle({Title = "Enable Auto Sell", Callback = function(s) _G.AutoSellActive = s end})

-- [[ TAB: INTEGRATION (WEBHOOK) ]]
local IntegrationTab = Window:Tab({Title = "Integration", Icon = "solar:settings-bold"})
IntegrationTab:Section({Title = "Discord Webhook"}):Input({
    Title = "Webhook URL", 
    Placeholder = "Paste URL di sini...", 
    Callback = function(v) _G.WebhookURL = v end
})
IntegrationTab:Section({Title = "Test Webhook"}):Button({Title = "Kirim Test Message", Callback = function()
    SendWebhook("✅ DapzX Atomic: Webhook Terhubung!")
    WindUI:Notify({Title = "Status", Content = "Pesan test telah dikirim!", Duration = 3})
end})

-- [[ MAIN LOOP FISHING ]]
task.spawn(function()
    local FishingSystem = ReplicatedStorage:WaitForChild("FishingSystem")
    while true do
        task.wait(0.5)
        if _G.FarmingActive and LocalPlayer.Character and LocalPlayer.Character:FindFirstChildWhichIsA("Tool") then
            local tool = LocalPlayer.Character:FindFirstChildWhichIsA("Tool")
            local root = LocalPlayer.Character.HumanoidRootPart
            local castPos = root.Position + (root.CFrame.LookVector * 15)
            
            FishingSystem.CastReplication:FireServer(castPos, root.Position, tool.Name, 99.5)
            task.wait(1.5)
            FishingSystem.PrecalcFish:InvokeServer()
            task.wait(_G.MinigameDelay)
            FishingSystem.FishGiver:FireServer({["hookPosition"] = castPos})
            FishingSystem.CleanupCast:FireServer()
            task.wait(1)
        end
    end
end)

-- [[ AUTO SELL LOOP ]]
task.spawn(function()
    while true do
        task.wait(60) -- 1 Menit sekali
        if _G.AutoSellActive then
            -- Tambahkan logika SellAllBatch Anda di sini
            SendWebhook("📦 Auto Sell: Ikan telah dijual!")
        end
    end
end)
