        local char = LP.Character
        if not char then N("Avatar","No character found.",3) return end

        pcall(function()
            local hum = char:FindFirstChildOfClass("Humanoid")
            if not hum then return end

            local model = Plrs:CreateHumanoidModelFromUserId(id)

            for _, obj in ipairs(char:GetChildren()) do
                if obj:IsA("Accessory") or obj:IsA("Shirt") or obj:IsA("Pants")
                or obj:IsA("ShirtGraphic") or obj:IsA("CharacterMesh") then
                    obj:Destroy()
                end
            end

            for _, obj in ipairs(model:GetChildren()) do
                if obj:IsA("Accessory") then
                    hum:AddAccessory(obj:Clone())
                elseif obj:IsA("Shirt") or obj:IsA("Pants")
                    or obj:IsA("ShirtGraphic") or obj:IsA("CharacterMesh") then
                    obj:Clone().Parent = char
                end
            end

            local bc1 = char:FindFirstChildWhichIsA("BodyColors")
            local bc2 = model:FindFirstChildWhichIsA("BodyColors")
            if bc1 and bc2 then bc1:Destroy(); bc2:Clone().Parent = char end

            local h1 = char:FindFirstChild("Head")
            local h2 = model:FindFirstChild("Head")
            if h1 and h2 then
                local f1 = h1:FindFirstChildOfClass("Decal")
                local f2 = h2:FindFirstChildOfClass("Decal")
                if f1 and f2 then f1.Texture = f2.Texture end
            end

            model:Destroy()
            N("Avatar","Applied successfully!",3)
        end)
    end,
})

