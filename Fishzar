    OpenButton = { Enabled = true, Title = "Open Flow" }
})

-- UI Header Info (Fixed Position)
Window.MainFrame.Header.Title.Text = "Flow Hub v1.2.5 | " .. execName

local Tabs = {
    Main = Window:Tab({ Title = "Main", Icon = "solar:home-bold" }),
    Player = Window:Tab({ Title = "Player", Icon = "solar:user-rounded-bold" }),
    Fishing = Window:Tab({ Title = "Fishing", Icon = "solar:fishing-rod-bold" }),
    Teleport = Window:Tab({ Title = "Teleport", Icon = "solar:map-point-wave-bold" }),
