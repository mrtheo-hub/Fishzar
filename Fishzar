-- Dot thread — killed by _alive flag (never polls .Parent)
task.spawn(function()
    local dots = {"·","· ·","· · ·","· ·"}; local i = 1
    while _alive do
        -- Strip old dots then append
        local base = lStatus.Text:gsub("%s*·.*$","")
        lStatus.Text = base.."  "..dots[i]
        i = i % #dots + 1
        task.wait(0.32)
    end
