-- [[ FLOW HUB OFFICIAL V2.4.0 ]]
-- FINAL STABLE | ANTI-SPAM & TAB RENDERING FIX

-- 1. TRIPLE-LOCK SYSTEM (Mencegah Spam UI)
if _G.FlowHubRunning then 
    return 
end
_G.FlowHubRunning = true

local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local CoreGui = game:GetService("CoreGui")

local Version = "2.4.0 (Stable)"
local Executor = (identifyexecutor and identifyexecutor()) or "Mobile"
local ValidKeys = {"FlowHub", "Dapz", "Mon", "Theo"}
local KeyFile = "FlowHub_Key.txt"

-- Cleanup Semua UI Lama (Anti-Stacking)
local function Cleanup()
    for _, v in pairs(CoreGui:GetChildren()) do
        if v.Name == "FlowHub_Auth" or v.Name == "WindUI" then 
            v:Destroy() 
        end
    end
end
Cleanup()

local function SaveK(k) writefile(KeyFile, k) end
local function ReadK() return isfile(KeyFile) and readfile(KeyFile) or "" end

-- ==========================================
