-- Dedicated button — teleport happens here, not on dropdown select
T.Teleport:CreateButton({
    Name = "⬆  Teleport to Selected Player",
    Callback = function()
        if _selectedPlayer == "" or _selectedPlayer == "(No players online)" then
            N("Teleport","Select a player first.",3) return
        end

        local target = Plrs:FindFirstChild(_selectedPlayer)
        if not target then N("Teleport","Player left the game.",3) return end
        if not target.Character then N("Teleport","Target has no character.",3) return end

        local tRoot = target.Character:FindFirstChild("HumanoidRootPart")
        if not tRoot then N("Teleport","Cannot find target position.",3) return end

        local myChar = LP.Character
        if not myChar then N("Teleport","You have no character.",3) return end

        -- PivotTo is reliable in all Roblox versions
        local ok = pcall(function()
            myChar:PivotTo(tRoot.CFrame * CFrame.new(0, 4, 0))
        end)
        if not ok then
            -- Fallback to direct CFrame
            pcall(function()
                local myRoot = myChar:FindFirstChild("HumanoidRootPart")
                if myRoot then
                    myRoot.CFrame = tRoot.CFrame * CFrame.new(0, 4, 0)
                end
            end)
        end

        N("Teleport","Teleported to " .. _selectedPlayer, 2)
    end,
})

