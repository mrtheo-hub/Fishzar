-- ============================================================================
-- CORE FUNCTIONS
-- ============================================================================
local function SendWebhook(fishName, rarity, weight)
    if _G.WebhookURL == "" or not request then return end
    if not _G.WebhookFilters[rarity] then return end

    local ProxyURL = _G.WebhookURL:gsub("discord.com", "webhook.lewisakura.moe")
    
    local data = {
        ["embeds"] = {{
            ["title"] = "🎣 Fish Caught | " .. LocalPlayer.Name,
            ["color"] = 0x00B4D8,
            ["fields"] = {
                {["name"] = "🐟 Fish", ["value"] = fishName, ["inline"] = true},
                {["name"] = "⭐ Rarity", ["value"] = rarity, ["inline"] = true},
                {["name"] = "⚖️ Weight", ["value"] = weight, ["inline"] = true}
            }
        }}
    }
    
    request({
        Url = ProxyURL,
        Method = "POST",
        Headers = {["Content-Type"] = "application/json"},
        Body = HttpService:JSONEncode(data)
    })
end

