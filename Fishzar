local AnimController = require(FishingSystem.FishingModules:WaitForChild("AnimationController"))

-- GLOBAL CONFIG
_G.Config = {Farming = false, Delay = 3, WalkWater = false, AntiDrown = false, Streamer = false, AntiStaff = false, AutoEquip = false, AutoSell = false}

-- [[ 1. UI SETUP ]]
