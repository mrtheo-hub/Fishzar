-- 2. TRANSITION LOGIC
-- ==========================================
local function SuccessAuth()
    LoadingText.Text = "ACCESS GRANTED"
    LoadingText.TextColor3 = Color3.new(0, 1, 0)
    KeyFrame:Destroy()
    task.wait(0.5)
    Screen:Destroy() -- Langsung hapus screen agar tidak stuck
    ExecuteFlowHub()
end

task.spawn(function()
    task.wait(2) -- Loading simulasi
    LoadingText.Visible = false
    KeyFrame.Visible = true
    
    local saved = ReadK()
    if table.find(ValidKeys, saved) then
        Input.Text = saved
        SuccessAuth()
    end
end)

Btn.MouseButton1Click:Connect(function()
    if table.find(ValidKeys, Input.Text) then
        SaveK(Input.Text)
        SuccessAuth()
    else
        LocalPlayer:Kick("Flow Hub: Invalid Key.")
    end
end)

