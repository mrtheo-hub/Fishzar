-- ── Loader helpers ──────────────────────────────────────
local function setProgress(pct, msg)
    TweenService:Create(barFill,
        TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
        { Size = UDim2.new(pct, 0, 1, 0) }
    ):Play()
    if msg then lblStatus.Text = msg end
end

local function dismissLoader()
    local info = TweenInfo.new(0.5, Enum.EasingStyle.Quad)
    for _, v in ipairs(loaderGui:GetDescendants()) do
        pcall(function()
            if v:IsA("TextLabel") or v:IsA("TextButton") then
                TweenService:Create(v, info, { TextTransparency = 1 }):Play()
            end
            if v:IsA("Frame") or v:IsA("ImageLabel") then
                TweenService:Create(v, info, { BackgroundTransparency = 1 }):Play()
            end
            if v:IsA("UIStroke") then
                TweenService:Create(v, info, { Transparency = 1 }):Play()
            end
        end)
    end
    TweenService:Create(overlay, info, { BackgroundTransparency = 1 }):Play()
    task.delay(0.65, function()
        if loaderGui and loaderGui.Parent then loaderGui:Destroy() end
    end)
end

