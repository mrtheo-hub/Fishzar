-- [[ 1. LOADING SCREEN ]]
local function CreateLoadingScreen()
    local Screen = Instance.new("ScreenGui", CoreGui)
    local Frame = Instance.new("Frame", Screen)
    Frame.Size = UDim2.new(1, 0, 1, 0); Frame.BackgroundColor3 = Color3.fromRGB(15, 15, 15)
    local Logo = Instance.new("ImageLabel", Frame)
    Logo.Image = "rbxassetid://88673887911141"; Logo.Size = UDim2.new(0, 150, 0, 150)
    Logo.Position = UDim2.new(0.5, -75, 0.5, -75); Logo.BackgroundTransparency = 1
    task.wait(2); TweenService:Create(Frame, TweenInfo.new(1), {BackgroundTransparency = 1}):Play()
    TweenService:Create(Logo, TweenInfo.new(1), {ImageTransparency = 1}):Play()
    task.wait(1); Screen:Destroy()
end
