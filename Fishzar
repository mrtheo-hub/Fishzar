-- [[ 3. WEBHOOK LOGIC (NEW BACKPACK WATCHER) ]]
local function SendWebhook(item)
    if not _G.WebhookURL or _G.WebhookURL == "" then return end
    local rarity = item:GetAttribute("rarity")
    if not rarity or not _G.FilterRarity[rarity] then return end
    
    local payload = {
        ["embeds"] = {{
            ["title"] = "🎣 Ikan Tertangkap!",
            ["color"] = 3447003,
            ["fields"] = {
                {["name"] = "Nama", ["value"] = tostring(item:GetAttribute("fishId") or item.Name), ["inline"] = true},
                {["name"] = "Rarity", ["value"] = tostring(rarity), ["inline"] = true},
                {["name"] = "Berat", ["value"] = tostring(item:GetAttribute("weight") or 0) .. " kg", ["inline"] = true}
            },
            ["footer"] = {["text"] = "DapzX Atomic System | " .. os.date("%X")}
        }}
    }
    pcall(function()
        (http_request or request or syn.request)({
            Url = _G.WebhookURL,
            Method = "POST",
            Headers = {["Content-Type"] = "application/json"},
            Body = HttpService:JSONEncode(payload)
        })
    end)
end

