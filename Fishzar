-- ==========================================
-- 3. TAB: FISHING (AUTO & REALTIME STATS)
-- ==========================================
local TabFish = Window:Tab({ Title = "Fishing", Icon = "solar:fishing-bold" })

-- [REAL TIME STATS UI]
TabFish:Section({ Title = "Real-Time Statistics" })
local PingLabel = TabFish:Section({ Title = "Ping: Fetching..." })
local FPSLabel = TabFish:Section({ Title = "FPS: Fetching..." })

task.spawn(function()
    while task.wait(0.1) do
        local fps = math.floor(1/RunService.RenderStepped:Wait())
        local ping = tonumber(string.format("%.0f", game:GetService("Stats").Network.ServerStatsItem["Data Ping"]:GetValue()))
        PingLabel:SetTitle("Ping: " .. ping .. " ms")
        FPSLabel:SetTitle("FPS: " .. fps)
    end
end)

TabFish:Section({ Title = "Automation" })
TabFish:Toggle({ Title = "Auto Fishing", Callback = function(v) getgenv().AutoFish = v end })
TabFish:Toggle({
    Title = "Auto Sell Fish",
    Callback = function(v)
        getgenv().AutoSell = v
        task.spawn(function()
            while getgenv().AutoSell do
                pcall(function()
                    for _, p in pairs(workspace:GetDescendants()) do
                        if p:IsA("ProximityPrompt") and p.ActionText:lower():match("sell") then
                            LocalPlayer.Character.HumanoidRootPart.CFrame = p.Parent.CFrame
                            task.wait(0.3)
                            fireproximityprompt(p)
                        end
                    end
                end)
                task.wait(2)
            end
        end)
    end
})

-- ==========================================
-- 4. TAB: PLAYER (MOVEMENT & TELEPORT PLAYER)
-- ==========================================
local TabPlayer = Window:Tab({ Title = "Player", Icon = "solar:user-bold" })

TabPlayer:Section({ Title = "Movement Settings" })
TabPlayer:Slider({ Title = "WalkSpeed", Min = 16, Max = 300, Default = 16, Callback = function(v) LocalPlayer.Character.Humanoid.WalkSpeed = v end })
TabPlayer:Slider({ Title = "JumpPower", Min = 50, Max = 500, Default = 50, Callback = function(v) LocalPlayer.Character.Humanoid.JumpPower = v end })

TabPlayer:Section({ Title = "Teleport to Player" })
local function getPlrs()
    local t = {}
    for _, v in pairs(Players:GetPlayers()) do if v ~= LocalPlayer then table.insert(t, v.Name) end end
    return t
end

local PlrDrop = TabPlayer:Dropdown({
    Title = "Select Player",
    Values = getPlrs(),
    Callback = function(v)
        local target = Players:FindFirstChild(v)
        if target and target.Character then
            LocalPlayer.Character.HumanoidRootPart.CFrame = target.Character.HumanoidRootPart.CFrame
        end
    end
})

TabPlayer:Button({ Title = "Refresh Player List", Callback = function() PlrDrop:SetValues(getPlrs()) end })

