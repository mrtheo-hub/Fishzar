-- ============================================================================
-- CORE LOOP
-- ============================================================================
task.spawn(function()
    while true do
        task.wait(0.5)
        if _G.FarmingActive then
            local remotes = GetRemotes()
            local char = LocalPlayer.Character
            local root = char and char:FindFirstChild("HumanoidRootPart")
            local rod = char and char:FindFirstChildWhichIsA("Tool") or LocalPlayer.Backpack:FindFirstChildWhichIsA("Tool")
            
            -- Auto Equip if in Backpack
            if rod and rod.Parent == LocalPlayer.Backpack then
                char.Humanoid:EquipTool(rod)
            end

            if root and rod and remotes and remotes.Cast then
                pcall(function()
                    local castPos = root.Position + (root.CFrame.LookVector * 20)
                    
                    -- Mencoba lempar dengan berbagai gaya argument (Fishzar Fix)
                    remotes.Cast:FireServer(castPos, root.Position, rod.Name, 100)
                    
                    task.wait(1.5)
                    
                    -- Win Spoofing
                    if remotes.Win then
                        if remotes.Win:IsA("RemoteFunction") then
                            remotes.Win:InvokeServer(true, 100)
                        else
                            remotes.Win:FireServer(true, 100)
                        end
                    end
                    
                    task.wait(_G.CatchDelay)
                    
                    -- Catching
                    if remotes.Catch then
                        remotes.Catch:FireServer({["hookPosition"] = castPos})
                        -- Cadangan jika format di atas salah:
                        remotes.Catch:FireServer(true) 
                    end
                end)
                task.wait(0.5)
            end
        end
    end
end)

