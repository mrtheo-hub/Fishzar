-- AUTO FARM (NEW INSPIRATION METHOD)
task.spawn(function()
    while true do
        task.wait(0.5)
        if _G.FarmingActive and FishingSystem then
            pcall(function()
                local char = LocalPlayer.Character
                local root = char and char:FindFirstChild("HumanoidRootPart")
                local tool = char and char:FindFirstChildWhichIsA("Tool")
                
                if not tool then
                    for _, v in pairs(LocalPlayer.Backpack:GetChildren()) do
                        if v:IsA("Tool") and (v.Name:lower():find("rod") or v:FindFirstChild("Handle")) then
                            char.Humanoid:EquipTool(v); task.wait(0.5); break
                        end
                    end
                    tool = char:FindFirstChildWhichIsA("Tool")
                end

                if char and root and tool then
                    local castPos = root.Position + (root.CFrame.LookVector * 15) + Vector3.new(0, -6, 0)
                    
                    -- Start Cast
                    if AnimController then AnimController:Play("PrepareCast", 0.1) end
                    FishingSystem.CastReplication:FireServer(castPos, root.Position, tool.Name, 99.5 + math.random())
                    
                    task.wait(1.5)
                    FishingSystem.PrecalcFish:InvokeServer()
                    task.wait(0.5)

                    -- Alert Hook
                    if AnimController then AnimController:Play("PullingAnimation", 0.1) end
                    FishingSystem.ReplicatePullAlert:FireServer("rbxassetid://76503247176490")

                    task.wait(_G.SettingsDelay) -- Tarik sesuai slider
                    
                    FishingSystem.FishGiver:FireServer({ ["hookPosition"] = castPos })
                    task.wait(0.3)

                    FishingSystem.CleanupCast:FireServer()
                    if AnimController then AnimController:Play("EquippedAnimation", 0.3) end
                    task.wait(1.5)
                end
            end)
        end
    end
end)

