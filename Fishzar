-- [LOOPS]
task.spawn(function()
    while task.wait(0.5) do
        PingL:SetTitle("Ping: " .. math.floor(Stats.Network.ServerStatsItem["Data Ping"]:GetValue()) .. "ms")
        FPSL:SetTitle("FPS: " .. math.floor(workspace:GetRealTimePhysicsFPS()))
    end
end)

RunService.RenderStepped:Connect(function()
    if _G.Config.WalkWater and LocalPlayer.Character and LocalPlayer.Character.HumanoidRootPart.Position.Y < 5 then
        LocalPlayer.Character.HumanoidRootPart.Velocity = Vector3.new(0, 5, 0)
    end
    if _G.Config.Drown and LocalPlayer.Character then
        LocalPlayer.Character.Humanoid:SetStateEnabled(Enum.HumanoidStateType.Swimming, false)
    end
    if _G.Config.Streamer then
        for _, p in pairs(Players:GetPlayers()) do
            if p.Character and p.Character:FindFirstChild("Head") then
                for _, v in pairs(p.Character.Head:GetChildren()) do if v:IsA("BillboardGui") then v.Enabled = false end end
            end
        end
    end
end)

-- [MANCING & WEBHOOK (LOCKED)]
LocalPlayer.Backpack.ChildAdded:Connect(function(i)
    if i:IsA("Tool") and _G.Config.Webhook ~= "" then
        local r = i:GetAttribute("rarity") or "Common"
        if _G.RarityFilter[r] then
            local data = {["content"]="Caught: "..i.Name.." ("..r..")"}
            pcall(function() (http_request or request)({Url=_G.Config.Webhook, Method="POST", Headers={["Content-Type"]="application/json"}, Body=HttpService:JSONEncode(data)}) end)
        end
    end
end)

task.spawn(function()
    while true do
        task.wait(0.5)
        if _G.Config.Farming and LocalPlayer.Character then
            pcall(function()
                local tool = LocalPlayer.Character:FindFirstChildWhichIsA("Tool")
                if tool then
                    local root = LocalPlayer.Character.HumanoidRootPart
                    local castPos = root.Position + (root.CFrame.LookVector * 15) + Vector3.new(0, -6, 0)
                    AnimController:Play("PrepareCast", 0.1)
                    FishingSystem.CastReplication:FireServer(castPos, root.Position, tool.Name, 99.5)
                    task.wait(1.5); FishingSystem.PrecalcFish:InvokeServer(); task.wait(0.5)
                    FishingSystem.ReplicatePullAlert:FireServer("rbxassetid://76503247176490")
                    task.wait(_G.Config.Delay)
                    FishingSystem.FishGiver:FireServer({ ["hookPosition"] = castPos })
                    task.wait(0.3); FishingSystem.CleanupCast:FireServer()
                    AnimController:Play("EquippedAnimation", 0.3); task.wait(1.5)
                end
            end)
        end
    end
end)
