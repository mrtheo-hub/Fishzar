-- [ PLAYER TAB ]
local lockedY = nil
Tabs.Player:AddToggle("WalkWater", { Title = "Walk on Water", Default = false }):OnChanged(function(v)
    FlowConfig.WalkWater = v
    if v and LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
        lockedY = LocalPlayer.Character.HumanoidRootPart.Position.Y - 3.2
    else lockedY = nil end
end)

Tabs.Player:AddToggle("AntiDrown", { Title = "Anti Drown", Default = false }):OnChanged(function(v)
    FlowConfig.AntiDrown = v
end)

Tabs.Player:AddToggle("AutoEquip", { Title = "Auto Equip Rod", Default = false }):OnChanged(function(v)
    FlowConfig.AutoEquip = v
end)

-- [ FISHING TAB ]
Tabs.Fishing:AddToggle("AutoFarm", { Title = "Auto Farm", Default = false }):OnChanged(function(v)
    FlowConfig.Farming = v
end)

Tabs.Fishing:AddInput("FarmDelay", {
    Title = "Cast Delay",
    Default = "3.0",
    Numeric = true,
    Finished = true,
    Callback = function(v) FlowConfig.Delay = tonumber(v) or 3.0 end
})

Tabs.Fishing:AddToggle("AutoSell", { Title = "Auto Sell Fish", Default = false }):OnChanged(function(v)
    FlowConfig.AutoSell = v
end)

-- [ TELEPORT TAB ]
local islandNames = {}
for name, _ in pairs(Islands) do table.insert(islandNames, name) end

Tabs.Teleport:AddDropdown("TeleLocation", {
    Title = "Teleport ke Pulau",
    Values = islandNames,
    Multi = false,
    Default = nil,
}):OnChanged(function(v)
    if Islands[v] and LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then 
        LocalPlayer.Character.HumanoidRootPart.CFrame = CFrame.new(Islands[v] + Vector3.new(0, 5, 0)) 
    end
end)

local function getPlrs()
    local t = {}
    for _,p in pairs(Players:GetPlayers()) do if p ~= LocalPlayer then table.insert(t, p.Name) end end
    return t
end

local PlayerTeleDropdown = Tabs.Teleport:AddDropdown("TelePlayer", {
    Title = "Teleport ke Player",
    Values = getPlrs(),
    Multi = false,
    Default = nil,
})

PlayerTeleDropdown:OnChanged(function(v)
    local target = Players:FindFirstChild(v)
    if target and target.Character and target.Character:FindFirstChild("HumanoidRootPart") then
        LocalPlayer.Character.HumanoidRootPart.CFrame = target.Character.HumanoidRootPart.CFrame * CFrame.new(0, 3, 0)
    end
end)

Tabs.Teleport:AddButton({
    Title = "Refresh Player List",
    Callback = function()
        PlayerTeleDropdown:SetValues(getPlrs())
    end
})

-- [ WEBHOOK TAB ]
Tabs.Webhook:AddInput("WebURL", {
    Title = "Webhook URL",
    Default = "",
    Finished = true,
    Callback = function(v) FlowConfig.WebhookURL = v end
})

Tabs.Webhook:AddToggle("WebDC", { Title = "Ping @everyone saat Disconnect", Default = false }):OnChanged(function(v)
    FlowConfig.WebhookDisconnect = v
end)

Tabs.Webhook:AddButton({
    Title = "Test Webhook",
    Callback = function()
        if FlowConfig.WebhookURL == "" then return end
        local request = (syn and syn.request) or (http and http.request) or http_request or request or HttpService.RequestAsync
        local data = {["embeds"]={{["title"]="✅ Flow Hub Fluent",["color"]=0x00B4D8}}}
        pcall(function() request({Url = FlowConfig.WebhookURL, Method = "POST", Headers = {["Content-Type"] = "application/json"}, Body = HttpService:JSONEncode(data)}) end)
    end
})

