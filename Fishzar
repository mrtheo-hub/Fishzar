-- ==========================================
-- 3. MAIN HUB ENGINE (SEQUENTIAL RENDER)
-- ==========================================
local isMainLoaded = false
local function StartFlowHub()
    if isMainLoaded then return end
    isMainLoaded = true
    
    Screen:Destroy() -- Hapus UI Login
    
    -- Load WindUI
    local WindUI = loadstring(game:HttpGet("https://raw.githubusercontent.com/Footagesus/WindUI/main/dist/main.lua"))()
    local Window = WindUI:CreateWindow({
        Title = "Flow Hub Official",
        Folder = "FlowHub_Data",
        Icon = "solar:waterdrop-bold",
        Size = UDim2.fromOffset(580, 460),
        Search = true
    })

    Window:Tag({ Title = "Exec: " .. Executor, Color = Color3.fromRGB(0, 180, 216) })
    Window:Tag({ Title = "Ver: " .. Version, Color = Color3.new(1,1,1) })

    -- SEQUENTIAL TAB LOADING (Mencegah Tab Kosong)
    task.wait(0.2)
    local Tab1 = Window:Tab({ Title = "Main", Icon = "solar:home-bold" })
    task.wait(0.1)
    Tab1:Section({ Title = "Information" })
    Tab1:Button({ Title = "Copy Discord Link", Callback = function() setclipboard("https://discord.gg/flowhub") end })

    task.wait(0.1)
    local Tab2 = Window:Tab({ Title = "Teleport", Icon = "solar:map-point-wave-bold" })
    task.wait(0.1)
    Tab2:Section({ Title = "Teleport List" })
    local Locs = {["Pulau Nelayan"] = Vector3.new(-34, 14, 256), ["Gua Crystaliz"] = Vector3.new(171, -142, -4938)}
    local n = {} for k,_ in pairs(Locs) do table.insert(n, k) end
    Tab2:Dropdown({ Title = "Select Island", Values = n, Callback = function(v) 
        LocalPlayer.Character.HumanoidRootPart.CFrame = CFrame.new(Locs[v]) 
    end})

    task.wait(0.1)
    local Tab3 = Window:Tab({ Title = "Utilities", Icon = "solar:settings-bold" })
    task.wait(0.1)
    Tab3:Section({ Title = "Settings" })
    Tab3:Toggle({ Title = "Walk on Water", Callback = function(v) _G.WoW = v end })
    Tab3:Button({ Title = "Rejoin", Callback = function() game:GetService("TeleportService"):Teleport(game.PlaceId, LocalPlayer) end })

    -- LOAD FISHZAR DI AKHIR AGAR TIDAK MENGGANGU UI RENDER
    task.spawn(function()
        pcall(function()
            loadstring(game:HttpGet("https://raw.githubusercontent.com/mrtheo-hub/Fishzar/refs/heads/main/Fishzar"))()
        end)
    end)
end

-- ==========================================
-- 4. LOGIN LOGIC
-- ==========================================
Btn.MouseButton1Click:Connect(function()
    if table.find(ValidKeys, Input.Text) then
        SaveK(Input.Text)
        StartFlowHub()
    else
        LocalPlayer:Kick("Key Salah!")
    end
end)

-- Auto Login Check
local saved = ReadK()
if table.find(ValidKeys, saved) then
    Input.Text = saved
    task.wait(0.5)
    StartFlowHub()
end
