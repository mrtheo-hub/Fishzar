local RunService = game:GetService("RunService")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Players = game:GetService("Players")
local HttpService = game:GetService("HttpService")
local LocalPlayer = Players.LocalPlayer

-- [[ LOAD UI ]]
local WindUI = loadstring(game:HttpGet("https://raw.githubusercontent.com/Footagesus/WindUI/main/dist/main.lua"))()

-- [[ CONFIG ]]
_G.FarmingActive = false
_G.AutoSellActive = false
_G.WebhookURL = ""
_G.MinigameDelay = 3.0

-- [[ UTILITY: DATA IKAN ]]
local function GetFishData(tool)
    if not tool or not tool:IsA("Tool") then return nil end
    local fId = tool:GetAttribute("fishId") or (tool:FindFirstChild("fishId") and tool.fishId.Value) or tool.Name
    local w = tool:GetAttribute("weight") or (tool:FindFirstChild("weight") and tool.weight.Value) or 0
    local r = tool:GetAttribute("rarity") or (tool:FindFirstChild("rarity") and tool.rarity.Value) or "Unknown"
    return {["weight"] = tonumber(w), ["rarity"] = tostring(r), ["fishId"] = tostring(fId)}
end

-- [[ UTILITY: WEBHOOK EMBED ]]
local function SendWebhook(fishList)
    if _G.WebhookURL == "" or not _G.WebhookURL:find("discord") then return end
    
    local fields = {}
    for i, v in ipairs(fishList) do
        if i > 15 then break end
        table.insert(fields, {
            ["name"] = "🐟 " .. tostring(v.fishId),
            ["value"] = "Rarity: " .. tostring(v.rarity) .. "\nWeight: " .. tostring(v.weight) .. "kg",
            ["inline"] = true
        })
    end

    local data = {
        ["embeds"] = {{
            ["title"] = "🎣 Fish Sold Report",
            ["description"] = "Berhasil menjual " .. #fishList .. " ekor ikan.",
            ["color"] = 65445,
            ["fields"] = fields
        }}
    }
    
    pcall(function()
        (http_request or request or syn.request)({
            Url = _G.WebhookURL,
            Method = "POST",
            Headers = {["Content-Type"] = "application/json"},
            Body = HttpService:JSONEncode(data)
        })
    end)
end

-- [[ FUNGSI SELL ]]
local function SellAllBatch()
    local fishBatch = {}
    local sellEvent = ReplicatedStorage:FindFirstChild("FishingSystem") and ReplicatedStorage.FishingSystem:FindFirstChild("SellFish")
    if not sellEvent then return end

    for _, item in pairs(LocalPlayer.Backpack:GetChildren()) do
        local data = GetFishData(item)
        if data then table.insert(fishBatch, data) end
    end

    if #fishBatch > 0 then
        sellEvent:FireServer("SellAllBatch", fishBatch)
        SendWebhook(fishBatch)
    end
end

