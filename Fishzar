local function makeStatBadge(parent, xPos, text, color)
    local f = Instance.new("Frame", parent)
    f.Size             = UDim2.new(0.33, -4, 1, -14)
    f.Position         = UDim2.new(xPos, 2, 0, 7)
    f.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
