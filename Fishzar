-- [[ 3. WEBHOOK LOGIC (FIXED) ]]
local function SendWebhook(data, isTest)
    if not _G.WebhookURL or _G.WebhookURL == "" then return end
    local payload = {
        ["embeds"] = {{
            ["title"] = isTest and "✅ Webhook Connected!" or "🎣 Ikan Tertangkap!",
            ["color"] = isTest and 65280 or 3447003,
            ["fields"] = not isTest and {
                {["name"] = "Ikan", ["value"] = tostring(data.fishId), ["inline"] = true},
                {["name"] = "Rarity", ["value"] = tostring(data.rarity), ["inline"] = true},
                {["name"] = "Berat", ["value"] = tostring(data.weight) .. " kg", ["inline"] = true}
            } or nil,
            ["footer"] = {["text"] = "DapzX Atomic | " .. os.date("%X")}
        }}
    }
    pcall(function()
        (http_request or request or syn.request)({
            Url = _G.WebhookURL,
            Method = "POST",
            Headers = {["Content-Type"] = "application/json"},
            Body = HttpService:JSONEncode(payload)
        })
    end)
end

