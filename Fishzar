--  [9] FISH THUMBNAIL HELPER
-- ═══════════════════════════
-- Tries several methods to get a displayable image URL for a caught fish tool.
-- Falls back to player headshot if nothing found.
local function getFishImageURL(tool)
    -- Method 1: explicit attribute
    for _, attr in ipairs({"ImageId","imageId","ThumbnailId","thumbnailId","Icon","icon"}) do
        local v = tool:GetAttribute(attr)
        if v then
            local id = tostring(v):match("%d+")
            if id then
                return "https://www.roblox.com/asset-thumbnail/image?assetId="..id.."&width=420&height=420&format=png"
            end
        end
    end

    -- Method 2: Handle mesh TextureId
    local handle = tool:FindFirstChild("Handle")
    if handle then
        local mesh = handle:FindFirstChildOfClass("SpecialMesh")
        if mesh and mesh.TextureId and mesh.TextureId ~= "" then
            local id = mesh.TextureId:match("%d+")
            if id then
                return "https://www.roblox.com/asset-thumbnail/image?assetId="..id.."&width=420&height=420&format=png"
            end
        end
        -- Method 3: Decal/Texture on Handle
        for _, obj in ipairs(handle:GetChildren()) do
            if obj:IsA("Decal") or obj:IsA("Texture") then
                local id = obj.Texture:match("%d+")
                if id then
                    return "https://www.roblox.com/asset-thumbnail/image?assetId="..id.."&width=420&height=420&format=png"
                end
            end
        end
    end

    -- Method 4: Tool TextureId (shirt-style icon)
    if tool.TextureId and tool.TextureId ~= "" then
        local id = tool.TextureId:match("%d+")
        if id then
            return "https://www.roblox.com/asset-thumbnail/image?assetId="..id.."&width=420&height=420&format=png"
        end
    end

    -- Fallback: player headshot
    return "https://www.roblox.com/headshot-thumbnail/image?userId="
        ..LP.UserId.."&width=420&height=420&format=png"
end

