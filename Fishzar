-- [[ 1. LOADING SCREEN ]]
local function CreateLoadingScreen()
    local Screen = Instance.new("ScreenGui", CoreGui)
    local Frame = Instance.new("Frame", Screen)
    Frame.Size = UDim2.new(1, 0, 1, 0); Frame.BackgroundColor3 = Color3.fromRGB(15, 15, 15)
    local Logo = Instance.new("ImageLabel", Frame)
    Logo.Image = "rbxassetid://88673887911141"; Logo.Size = UDim2.new(0, 150, 0, 150)
    Logo.Position = UDim2.new(0.5, -75, 0.5, -75); Logo.BackgroundTransparency = 1
    task.wait(2); TweenService:Create(Frame, TweenInfo.new(1), {BackgroundTransparency = 1}):Play()
    TweenService:Create(Logo, TweenInfo.new(1), {ImageTransparency = 1}):Play()
    task.wait(1); Screen:Destroy()
end
CreateLoadingScreen()

-- [[ 2. CONFIG ]]
_G.Version = "v3.9.0"
_G.FarmingActive = false
_G.AutoSellActive = false
_G.WalkOnWater = false
_G.WebhookURL = ""
_G.MinigameDelay = 0.1 -- Default Instant
_G.FilterRarity = {["Common"]=true,["Uncommon"]=true,["Rare"]=true,["Epic"]=true,["Legendary"]=true,["Secret"]=true}

-- [[ 3. WEBHOOK NOTIF ]]
local function TestWebhook()
    if _G.WebhookURL == "" or not _G.WebhookURL:match("discord.com/api/webhooks") then return end
    local data = {embeds = {{
        title = "✅ Webhook Connected!",
        description = "Koneksi ke **DapzX Atomic** Berhasil!\nInstant Fishing: **Active**",
        color = 65280,
        footer = {text = "System Check | "..os.date("%X")}
    }}}
    pcall(function() (http_request or request or syn.request)({Url = _G.WebhookURL, Method = "POST", Headers = {["Content-Type"] = "application/json"}, Body = HttpService:JSONEncode(data)}) end)
end

local function SendWebhook(item)
    if _G.WebhookURL == "" or not _G.FilterRarity[item:GetAttribute("rarity")] then return end
    local data = {embeds = {{
        title = "🎣 Ikan Tertangkap!",
        color = 3447003,
        fields = {
            {name = "Nama", value = item:GetAttribute("fishId") or item.Name, inline = true},
            {name = "Rarity", value = item:GetAttribute("rarity") or "Unknown", inline = true},
            {name = "Berat", value = (item:GetAttribute("weight") or 0) .. " kg", inline = true}
        },
        footer = {text = "DapzX Atomic System | "..os.date("%X")}
    }}}
    pcall(function() (http_request or request)({Url = _G.WebhookURL, Method = "POST", Headers = {["Content-Type"] = "application/json"}, Body = HttpService:JSONEncode(data)}) end)
end

