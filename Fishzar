-- 6. TAB: UTILITIES (PHYSICS FIX)
-- ==========================================
local TabUtil = Window:Tab({ Title = "Utilities", Icon = "solar:settings-bold" })

TabUtil:Toggle({ Title = "Streamer Mode (Hide Name)", Callback = function(v)
    getgenv().Streamer = v
    task.spawn(function()
        while getgenv().Streamer do
            pcall(function()
                local tag = LocalPlayer.Character:FindFirstChild("NameLabel", true) or LocalPlayer.Character:FindFirstChild("namelabel", true)
                if tag then tag.Visible = false end
            end)
            task.wait(1)
        end
    end)
end})

local waterP
TabUtil:Toggle({ Title = "Walk on Water (Safe)", Callback = function(v)
    getgenv().WoW = v
    if v then
        waterP = Instance.new("Part", workspace)
        waterP.Name = "FlowHub_WaterPart"
        waterP.Size = Vector3.new(2000, 1, 2000)
        waterP.Transparency = 1
        waterP.Anchored = true
        local y = LocalPlayer.Character.HumanoidRootPart.Position.Y - 3.4
        task.spawn(function()
            while getgenv().WoW do
                if LocalPlayer.Character then
                    waterP.Position = Vector3.new(LocalPlayer.Character.HumanoidRootPart.Position.X, y, LocalPlayer.Character.HumanoidRootPart.Position.Z)
                end
                task.wait()
            end
        end)
    else
        if waterP then waterP:Destroy() end
    end
end})

TabUtil:Toggle({ Title = "Anti Drown (Keep Health)", Callback = function(v)
    getgenv().AntiDrown = v
    task.spawn(function()
        while getgenv().AntiDrown do
            pcall(function()
                if LocalPlayer.Character.Humanoid:GetState() == Enum.HumanoidStateType.Swimming then
                    LocalPlayer.Character.Humanoid.Health = LocalPlayer.Character.Humanoid.MaxHealth
                end
            end)
            task.wait(0.5)
        end
    end)
end})

