-- ============================================================================
-- PREDATOR SCANNER (Mencari Remote di Seluruh Game)
-- ============================================================================
local FoundCast, FoundCatch, FoundWin

local function DeepScan()
    for _, v in pairs(game:GetDescendants()) do
        if v:IsA("RemoteEvent") or v:IsA("RemoteFunction") then
            local n = v.Name:lower()
            if n:find("cast") or n:find("throw") or n:find("line") then
                FoundCast = v
            elseif n:find("giver") or n:find("claim") or n:find("catch") then
                FoundCatch = v
            elseif n:find("win") or n:find("finish") or n:find("result") then
                FoundWin = v
            end
        end
    end
end

DeepScan() -- Jalankan scan saat script dimulai

