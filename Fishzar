-- [[ 5. AUTO FARM CORE (REMOTE + CLICK HYBRID) ]]
task.spawn(function()
    local FishingSystem = ReplicatedStorage:WaitForChild("FishingSystem")
    while true do
        task.wait(1)
        if _G.FarmingActive and LocalPlayer.Character then
            local tool = LocalPlayer.Character:FindFirstChildWhichIsA("Tool")
            if tool then
                -- Step 1: Lempar
                local root = LocalPlayer.Character.HumanoidRootPart
                local castPos = root.Position + (root.CFrame.LookVector * 15)
                FishingSystem.CastReplication:FireServer(castPos, root.Position, tool.Name, 100)
                
                -- Step 2: Deteksi Ikan Makan (Bypass Bengong)
                -- Kita tunggu signal dari game atau tarik paksa setelah delay
                task.wait(3.5) 
                
                -- Step 3: Tarik
                FishingSystem.FishGiver:FireServer({["hookPosition"] = castPos})
                
                -- Step 4: Cleanup & Reset
                task.wait(1)
                FishingSystem.CleanupCast:FireServer()
                task.wait(2) -- Jeda aman
            end
        end
    end
end)

-- [[ 6. AUTO SELL ]]
task.spawn(function()
    while true do
        task.wait(15)
        if _G.AutoSellActive then
            pcall(function()
                local fs = ReplicatedStorage:WaitForChild("FishingSystem")
                local sellRemote = fs:FindFirstChild("SellFish") or fs:FindFirstChild("SellAllBatch")
                local items = {}
                for _, v in pairs(LocalPlayer.Backpack:GetChildren()) do
                    if v:IsA("Tool") and v:GetAttribute("rarity") then table.insert(items, v) end
                end
                if #items > 0 then sellRemote:FireServer("SellAllBatch", items) end
            end)
        end
    end
end)
