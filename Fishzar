-- Dismiss: fade card + bg, destroy after animation
local function dismissLoader()
    _alive = false
    local t = TweenInfo.new(0.38, Enum.EasingStyle.Quad)
    Tween:Create(lBG,   t, {BackgroundTransparency=1}):Play()
    Tween:Create(lCard, t, {BackgroundTransparency=1}):Play()
    for _, v in ipairs(lCard:GetDescendants()) do
        pcall(function()
            if v:IsA("TextLabel") then
                Tween:Create(v,t,{TextTransparency=1,BackgroundTransparency=1}):Play()
            elseif v:IsA("Frame") then
                Tween:Create(v,t,{BackgroundTransparency=1}):Play()
            elseif v:IsA("UIStroke") then
                Tween:Create(v,t,{Transparency=1}):Play()
            end
        end)
    end
    task.delay(0.42, function()
        if loaderGui and loaderGui.Parent then loaderGui:Destroy() end
    end)
end

