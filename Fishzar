-- 2. TAB: MAIN (CHANGELOG & PERFORMANCE)
-- ==========================================
local TabMain = Window:Tab({ Title = "Main", Icon = "solar:home-bold" })

TabMain:Section({ Title = "Changelog V1.0.0" })
TabMain:Section({ Title = "- Official Release\n- Fixed Physics (WoW & Anti-Drown)\n- Added Player & Stats Features\n- No Key / No Loading", TextSize = 12 })

TabMain:Section({ Title = "Performance Mode" })
TabMain:Button({ -- [PERFORMANCE AS BUTTON]
    Title = "Ultra FPS Boost", 
    Callback = function() 
        settings().Rendering.QualityLevel = 1
