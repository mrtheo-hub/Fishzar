                    for _, headChild in pairs(p.Character:FindFirstChild("Head"):GetChildren()) do
                        if headChild:IsA("BillboardGui") then headChild.Enabled = false end
                    end
                end
            end
        end

        -- 2. Auto Sell Loop
        if _G.AutoSellActive then
            SellAllLogic()
            task.wait(2) -- Jangan terlalu cepat agar tidak lag
        end

        -- 3. Old Fishing Logic (Restored)
        if _G.FarmingActive and FishingSystem and CastingModule then
            pcall(function()
                local char = LocalPlayer.Character
                local rodName = (char:FindFirstChildWhichIsA("Tool") and char:FindFirstChildWhichIsA("Tool").Name)
                if char and rodName then
                    local root = char.HumanoidRootPart
                    local castPos = root.Position + (root.CFrame.LookVector * 15) + Vector3.new(0, -6, 0)
                    
                    if AnimController then AnimController:Play("PrepareCast", 0.1) end
                    FishingSystem.CastReplication:FireServer(castPos, root.Position, rodName, 99.5 + math.random())
                    
