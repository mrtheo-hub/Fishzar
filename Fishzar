-- [[ 3. WEBHOOK LOGIC (BACKPACK WATCHER) ]]
local function SendWebhook(item)
    if not _G.WebhookURL or _G.WebhookURL == "" then return end
    local rarity = item:GetAttribute("rarity") or (item:FindFirstChild("Stats") and item.Stats:FindFirstChild("Rarity") and item.Stats.Rarity.Value) or "Unknown"
    if not _G.FilterRarity[tostring(rarity)] then return end

    local payload = {
        ["embeds"] = {{
            ["title"] = "🎣 Ikan Tertangkap!",
            ["color"] = 3447003,
            ["fields"] = {
                {["name"] = "Nama", ["value"] = tostring(item:GetAttribute("fishId") or item.Name), ["inline"] = true},
                {["name"] = "Rarity", ["value"] = tostring(rarity), ["inline"] = true}
            },
            ["footer"] = {["text"] = "DapzX Atomic | " .. os.date("%X")}
        }}
    }
    pcall(function() (http_request or request or syn.request)({Url = _G.WebhookURL, Method = "POST", Headers = {["Content-Type"] = "application/json"}, Body = HttpService:JSONEncode(payload)}) end)
end

LocalPlayer.Backpack.ChildAdded:Connect(function(item)
    if item:IsA("Tool") then task.wait(1); SendWebhook(item) end
end)

