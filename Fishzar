local function GetFishData(tool)
    if not tool or not tool:IsA("Tool") then return nil end
    local fId = tool:GetAttribute("fishId") or tool:GetAttribute("FishId")
    local w = tool:GetAttribute("weight") or tool:GetAttribute("Weight")
    local r = tool:GetAttribute("rarity") or tool:GetAttribute("Rarity")
    if fId and w and r then
        return {["weight"] = tonumber(w), ["rarity"] = tostring(r), ["fishId"] = tostring(fId)}
    end
    return nil
end

local function SellAllLogic()
    local sellEvent = ReplicatedStorage:FindFirstChild("FishingSystem") and ReplicatedStorage.FishingSystem:FindFirstChild("SellFish")
    if not sellEvent then return end
    local fishBatch = {}
    for _, item in pairs(LocalPlayer.Backpack:GetChildren()) do
        local d = GetFishData(item)
        if d then table.insert(fishBatch, d) end
    end
    if #fishBatch > 0 then
        sellEvent:FireServer("SellAllBatch", fishBatch)
    end
end

-- Webhook Proxy Fix (Discord bypass)
local function SendWebhook(fishData)
    if _G.WebhookURL == "" or not request then return end
    if not _G.WebhookFilters[fishData.rarity] then return end

    -- Otomatis ubah link ke proxy agar tidak diblokir Discord
    local CleanURL = _G.WebhookURL:gsub("discord.com", "hooks.hyra.io")
    
    local embed = {
        ["title"] = "🎣 Fish Caught | " .. LocalPlayer.Name,
        ["color"] = 0xFF006E,
        ["fields"] = {
            {["name"] = "🐟 Fish", ["value"] = fishData.fishId or "Unknown", ["inline"] = true},
            {["name"] = "⭐ Rarity", ["value"] = fishData.rarity or "Unknown", ["inline"] = true},
            {["name"] = "⚖️ Weight", ["value"] = tostring(fishData.weight) .. " kg", ["inline"] = true}
        },
        ["footer"] = {["text"] = "DapzX Atomic v14.0.2"}
    }
    
    pcall(function()
        request({
            Url = CleanURL,
            Method = "POST",
            Headers = {["Content-Type"] = "application/json"},
            Body = HttpService:JSONEncode({["embeds"] = {embed}})
        })
    end)
end

