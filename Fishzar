    Callback = function()
        SendWebhook("Connection Test", "✅ DapzX Atomic berhasil terhubung ke Discord!")
        Fluent:Notify({Title = "Status", Content = "Pesan tes telah dikirim!", Duration = 3})
    end
})

-- TELEPORT TAB
Tabs.Teleport:AddButton({Title = "Ke Pulau Nelayan", Callback = function() LocalPlayer.Character.HumanoidRootPart.CFrame = CFrame.new(-34.59, 14.43, 256.65) end})

-- LOOPS
task.spawn(function()
    local FishingSystem = ReplicatedStorage:WaitForChild("FishingSystem")
    while true do
        task.wait(0.5)
        if _G.FarmingActive and LocalPlayer.Character and LocalPlayer.Character:FindFirstChildWhichIsA("Tool") then
            local tool = LocalPlayer.Character:FindFirstChildWhichIsA("Tool")
            local root = LocalPlayer.Character.HumanoidRootPart
            local castPos = root.Position + (root.CFrame.LookVector * 15)
            
            FishingSystem.CastReplication:FireServer(castPos, root.Position, tool.Name, 99.5)
            task.wait(1.5)
            FishingSystem.PrecalcFish:InvokeServer()
            task.wait(_G.MinigameDelay)
            FishingSystem.FishGiver:FireServer({["hookPosition"] = castPos})
            FishingSystem.CleanupCast:FireServer()
            task.wait(1)
        end
    end
end)

Fluent:Notify({Title = "DapzX Atomic", Content = "Script Berhasil Dimuat!", Duration = 5})
