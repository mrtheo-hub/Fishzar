local function serverHop(low)
    pcall(function()
        local order = low and "Asc" or "Desc"
        local raw   = game:HttpGet("https://games.roblox.com/v1/games/"
            ..game.PlaceId.."/servers/Public?sortOrder="..order.."&limit=100")
        local data  = HttpService:JSONDecode(raw).data or {}
        local valid = {}
        for _, s in ipairs(data) do
            if s.id and s.playing and s.maxPlayers
            and s.playing < s.maxPlayers
            and s.id ~= game.JobId then
                table.insert(valid, s.id)
            end
        end
        if #valid == 0 then Notify("Server Hop","No servers found.",3) return end
        TeleportService:TeleportToPlaceInstance(
            game.PlaceId, valid[math.random(1, #valid)], LocalPlayer)
    end)
end

