local function doServerHop(lowPop)
    local ok, err = pcall(function()
        local order = lowPop and "Asc" or "Desc"
        local url   = "https://games.roblox.com/v1/games/" .. game.PlaceId
                      .. "/servers/Public?sortOrder=" .. order .. "&limit=100"
        local raw   = game:HttpGet(url)
        local decoded = HttpService:JSONDecode(raw)
        local valid = {}
        for _, s in pairs(decoded.data or {}) do
            if s.id and s.playing and s.maxPlayers
            and s.playing < s.maxPlayers
            and s.id ~= game.JobId then
                table.insert(valid, s.id)
            end
        end
        if #valid == 0 then
            Notify("Server Hop", "No suitable servers found.", 3)
            return
        end
        TeleportService:TeleportToPlaceInstance(
            game.PlaceId, valid[math.random(1, #valid)], LocalPlayer)
    end)
    if not ok then Notify("Server Hop Error", tostring(err), 5) end
end

