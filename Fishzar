-- [[ 5. MAIN LOOPS ]]

-- FISHING LOOP
task.spawn(function()
    local FishingSystem = ReplicatedStorage:WaitForChild("FishingSystem")
    while true do
        task.wait(1)
        if _G.FarmingActive and LocalPlayer.Character then
            local tool = LocalPlayer.Character:FindFirstChildWhichIsA("Tool")
            local root = LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
            
            if tool and root then
                local castPos = root.Position + (root.CFrame.LookVector * 20)
                
                -- LEMPAR
                FishingSystem.CastReplication:FireServer(castPos, root.Position, tool.Name, 100)
                
                -- TUNGGU IKAN MAKAN (DELAY)
                task.wait(_G.CastDelay)
                
                -- TARIK
                FishingSystem.FishGiver:FireServer({["hookPosition"] = castPos})
                
                -- CEK HASIL UNTUK WEBHOOK
                task.wait(0.5)
                for _, item in pairs(LocalPlayer.Backpack:GetChildren()) do
                    if item:IsA("Tool") and item:GetAttribute("rarity") then
                        SendWebhook({
                            fishId = item:GetAttribute("fishId") or item.Name,
                            rarity = item:GetAttribute("rarity"),
                            weight = item:GetAttribute("weight") or 0
                        }, false)
                    end
                end
                
                -- BERSIHKAN KAIL
                FishingSystem.CleanupCast:FireServer()
                task.wait(2)
            end
        end
    end
end)

-- AUTO SELL LOOP
task.spawn(function()
    while true do
        task.wait(10)
        if _G.AutoSellActive then
            pcall(function()
                local fs = ReplicatedStorage:FindFirstChild("FishingSystem")
                local sellRemote = fs:FindFirstChild("SellFish") or fs:FindFirstChild("SellAll")
                local items = {}
                for _, v in pairs(LocalPlayer.Backpack:GetChildren()) do
                    if v:IsA("Tool") and v:GetAttribute("rarity") then table.insert(items, v) end
                end
                if #items > 0 then sellRemote:FireServer("SellAllBatch", items) end
            end)
        end
    end
end)
