waterPart.Name = "FlowWaterPlatform"; waterPart.Size = Vector3.new(20, 1, 20); waterPart.Transparency = 1; waterPart.Anchored = true

game:GetService("CoreGui").RobloxPromptGui.promptOverlay.ChildAdded:Connect(function(c)
    if c.Name == "ErrorPrompt" and FlowConfig.WebhookDisconnect and FlowConfig.WebhookURL ~= "" then
        local msg = c:FindFirstChild("ErrorMessage", true)
        request({Url = FlowConfig.WebhookURL, Method = "POST", Headers = {["Content-Type"] = "application/json"}, Body = HttpService:JSONEncode({["embeds"]={{["title"]="⚠️ Safety Kick",["description"]="**User:** "..LocalPlayer.Name.."\n**Reason:** "..(msg and msg.Text or "Unknown"),["color"]=0xFF0000}}})})
    end
end)

Players.PlayerAdded:Connect(function(p)
    if FlowConfig.AntiStaff and p:GetRankInGroup(0) > 0 then sHop(true) end -- Trigger hop if any group member joins
end)

LocalPlayer.Backpack.ChildAdded:Connect(function(item)
    if item:IsA("Tool") and not item.Name:lower():find("rod") then
        task.spawn(function()
            task.wait(1.5)
            local rar = item:GetAttribute("Rarity") or item:GetAttribute("rarity") or "Common"
            if FlowConfig.WebhookFilters[rar] and FlowConfig.WebhookURL ~= "" then
                local d = {["embeds"]={{["title"]="🎣 Fish Caught",["color"]=RarityColors[rar] or 0x00B4D8,["fields"]={{["name"]="Name",["value"]=item.Name,["inline"]=true},{["name"]="Rarity",["value"]=rar,["inline"]=true}}}}}
                pcall(function() request({Url = FlowConfig.WebhookURL, Method = "POST", Headers = {["Content-Type"] = "application/json"}, Body = HttpService:JSONEncode(d)}) end)
            end
        end)
    end
end)

getgenv().FlowConnection = RunService.Heartbeat:Connect(function()
    if FlowConfig.WalkWater and lockedY and LocalPlayer.Character then
        waterPart.CFrame = CFrame.new(LocalPlayer.Character.HumanoidRootPart.Position.X, lockedY, LocalPlayer.Character.HumanoidRootPart.Position.Z)
    else waterPart.CFrame = CFrame.new(0, -999, 0) end
end)

task.spawn(function()
    while task.wait(1) do
        local char = LocalPlayer.Character
        if char then
            if FlowConfig.AntiDrown then
                local hum = char:FindFirstChild("Humanoid")
                if hum then hum:SetStateEnabled(Enum.HumanoidStateType.Swimming, false) end
                for _, v in pairs(char:GetDescendants()) do if v.Name == "Oxygen" or v.Name == "O2" then v.Value = 100 end end
            end
            if FlowConfig.AutoEquip and not char:FindFirstChildWhichIsA("Tool") then
                for _, i in pairs(LocalPlayer.Backpack:GetChildren()) do if i:IsA("Tool") and i.Name:lower():find("rod") then char.Humanoid:EquipTool(i); break end end
            end
            if FlowConfig.AutoSell then pcall(function() ReplicatedStorage:FindFirstChild("SellFish", true):InvokeServer() end) end
        end
    end
end)

task.spawn(function()
    while task.wait(0.5) do
        if FlowConfig.Farming and LocalPlayer.Character and FishingSystem then
            pcall(function()
                local tool = LocalPlayer.Character:FindFirstChildWhichIsA("Tool")
                if tool and tool.Name:lower():find("rod") then
                    local root = LocalPlayer.Character.HumanoidRootPart
                    local castPos = root.Position + (root.CFrame.LookVector * 15)
                    FishingSystem.CastReplication:FireServer(castPos, root.Position, tool.Name, 99.5)
                    task.wait(2.0); FishingSystem.FishGiver:FireServer({["hookPosition"]=castPos})
                    task.wait(1.5); FishingSystem.CleanupCast:FireServer()
                end
            end)
        end
    end
end)
