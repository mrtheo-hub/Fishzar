-- [UTILITIES]
local function sHop(low)
    local raw = game:HttpGet("https://games.roblox.com/v1/games/" .. game.PlaceId .. "/servers/Public?sortOrder="..(low and "Asc" or "Desc").."&limit=100")
    local d = HttpService:JSONDecode(raw)
    for _,v in pairs(d.data) do if v.playing < v.maxPlayers and v.id ~= game.JobId then TeleportService:TeleportToPlaceInstance(game.PlaceId, v.id, LocalPlayer); break end end
end

