-- [ TABS CONTENT ]
Tabs.Main:Paragraph({ Title = "Final Update 1.2.5", Content = "- Fixed Rarity Detection (Async Delay)\n- Added Disconnect Logger\n- Optimized UI & Performance\n- Final Polish for release." })

Tabs.Player:Toggle({ Title = "Walk on Water", Callback = function(v) FlowConfig.WalkWater = v end })
Tabs.Player:Toggle({ Title = "Anti Drown", Callback = function(v) FlowConfig.AntiDrown = v end })

Tabs.Fishing:Toggle({ Title = "Auto Farm", Callback = function(v) FlowConfig.Farming = v end })
Tabs.Fishing:Input({ Title = "Delay", Placeholder = "3.0", Callback = function(v) FlowConfig.Delay = tonumber(v) or 3.0 end })
