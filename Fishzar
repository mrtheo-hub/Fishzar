-- [[ 2. WEBHOOK & FISH MONITOR ]]
local function SendWebhook(item)
    if not _G.WebhookURL or _G.WebhookURL == "" then return end
    local r = item:GetAttribute("rarity") or "Unknown"
    if not _G.FilterRarity[tostring(r)] then return end
    local p = {["embeds"]={{["title"]="🎣 Ikan!", ["fields"]={{["name"]="Nama",["value"]=item.Name}, {["name"]="Rarity",["value"]=tostring(r)}}}}}
    pcall(function() (http_request or request)({Url=_G.WebhookURL, Method="POST", Headers={["Content-Type"]="application/json"}, Body=HttpService:JSONEncode(p)}) end)
end

LocalPlayer.Backpack.ChildAdded:Connect(function(i) if i:IsA("Tool") then task.wait(0.5); SendWebhook(i) end end)

