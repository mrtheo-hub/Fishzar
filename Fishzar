-- [[ 5. MAIN LOOPS ]]
local WaterPart
RunService.RenderStepped:Connect(function()
    if _G.WalkOnWater and LocalPlayer.Character then
        if not WaterPart then WaterPart = Instance.new("Part", workspace); WaterPart.Anchored = true; WaterPart.Transparency = 1; WaterPart.Size = Vector3.new(500, 1, 500) end
        WaterPart.Position = Vector3.new(LocalPlayer.Character.HumanoidRootPart.Position.X, 4.5, LocalPlayer.Character.HumanoidRootPart.Position.Z)
    elseif WaterPart then WaterPart:Destroy(); WaterPart = nil end
end)

-- Fishing Loop (INSTANT FIX)
task.spawn(function()
    local FishingSystem = ReplicatedStorage:WaitForChild("FishingSystem")
    while true do
        task.wait(0.1)
        if _G.FarmingActive and LocalPlayer.Character then
            local tool = LocalPlayer.Character:FindFirstChildWhichIsA("Tool")
            local root = LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
            if tool and root then
                local castPos = root.Position + (root.CFrame.LookVector * 15)
                
                -- Instant Cast
                FishingSystem.CastReplication:FireServer(castPos, root.Position, tool.Name, 99.5)
                task.wait(_G.MinigameDelay) -- Delay minimal
                
                -- Instant Giver
                FishingSystem.FishGiver:FireServer({["hookPosition"] = castPos})
                
                -- Webhook & Cleanup
                task.wait(0.2)
                for _, item in pairs(LocalPlayer.Backpack:GetChildren()) do
                    if item:IsA("Tool") and item:GetAttribute("rarity") then SendWebhook(item) end
                end
                FishingSystem.CleanupCast:FireServer()
                task.wait(1.5) -- Delay antar tarikan agar tidak mencurigakan/kick
            end
        end
    end
end)

-- Auto Sell
task.spawn(function()
    while task.wait(15) do
        if _G.AutoSellActive then
            local sellEvent = ReplicatedStorage:FindFirstChild("FishingSystem"):FindFirstChild("SellFish")
            local inv = {}
            for _, i in pairs(LocalPlayer.Backpack:GetChildren()) do if i:IsA("Tool") then table.insert(inv, i) end end
            if #inv > 0 and sellEvent then sellEvent:FireServer("SellAllBatch", inv) end
        end
    end
end)
