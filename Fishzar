task.spawn(function()
    while task.wait(1) do
        local char = LocalPlayer.Character
        if not char then continue end
        local hum = char:FindFirstChildOfClass("Humanoid")

        -- Auto Sell
        if FC.AutoSell then
            pcall(function()
                local r = ReplicatedStorage:FindFirstChild("SellFish", true)
                       or ReplicatedStorage:FindFirstChild("Sell",     true)
                       or ReplicatedStorage:FindFirstChild("SellAll",  true)
                if not r then return end
                local m = FC.SellMode
                if m == "invoke" or (m == "auto" and r:IsA("RemoteFunction")) then
                    r:InvokeServer()
                elseif m == "fire" or (m == "auto" and r:IsA("RemoteEvent")) then
                    r:FireServer()
                end
            end)
        end

        -- Anti Drown
        if FC.AntiDrown and hum then
            pcall(function()
                hum:SetStateEnabled(Enum.HumanoidStateType.Swimming, false)
                for _, v in ipairs(char:GetDescendants()) do
                    if v:IsA("NumberValue") or v:IsA("IntValue") then
                        local vn = v.Name:lower()
                        if vn == "oxygen" or vn == "o2" or vn == "air" then
                            v.Value = 100
                        end
                    end
                end
            end)
        elseif hum then
            pcall(function()
                hum:SetStateEnabled(Enum.HumanoidStateType.Swimming, true)
            end)
        end

        -- Auto Equip Rod
        if FC.AutoEquip and hum and not char:FindFirstChildWhichIsA("Tool") then
            for _, item in ipairs(LocalPlayer.Backpack:GetChildren()) do
                if item:IsA("Tool") then
                    local in_ = item.Name:lower()
                    if in_:find("rod") or in_:find("kail") or in_:find("fishing") then
                        pcall(function() hum:EquipTool(item) end)
                        break
                    end
                end
            end
        end

        -- Streamer Mode
        if FC.Streamer then
            for _, p in ipairs(Players:GetPlayers()) do
                if p.Character then
                    for _, v in ipairs(p.Character:GetDescendants()) do
                        pcall(function()
                            if v:IsA("BillboardGui") then
                                v.Enabled = false
                            elseif v:IsA("TextLabel") then
                                local vn = v.Name:lower()
                                if vn:find("name") or vn:find("overhead") then
                                    v.Visible = false
                                end
                            end
                        end)
                    end
                end
            end
        end
    end
end)

