local _sessionCaught = 0     -- session fish counter

task.spawn(function()
    while task.wait(0.5) do
        if not C.Farming  then continue end
        if not FS         then continue end
        if _casting       then continue end  -- previous cast still running

        local char = LP.Character; if not char then continue end
