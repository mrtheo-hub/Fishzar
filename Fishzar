-- Wait up to 10 seconds for FishingSystem to exist
local FishingSystem = ReplicatedStorage:WaitForChild("FishingSystem", 10)

-- Safely require AnimationController
local AnimController = nil
if FishingSystem then
    local ok, result = pcall(function()
        local modules = FishingSystem:WaitForChild("FishingModules", 5)
        if modules then
            local animMod = modules:FindFirstChild("AnimationController")
            if animMod then return require(animMod) end
        end
    end)
    if ok and result then AnimController = result end
end

-- Cache remotes once (avoid FindFirstChild spam in hot loops)
local Remotes = {}
local function getRemote(name)
    if Remotes[name] ~= nil then return Remotes[name] end
    if not FishingSystem then Remotes[name] = false; return false end
    local r = FishingSystem:FindFirstChild(name, true)
    Remotes[name] = r or false
    return Remotes[name]
end

