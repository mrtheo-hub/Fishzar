-- Returns true if `tool` matches the configured rod keyword.
-- If keyword is empty, ANY tool is accepted (works with high-level rods).
local function isRod(tool)
    if not tool or not tool:IsA("Tool") then return false end
    local kw = C.RodKeyword:lower():match("^%s*(.-)%s*$")
    if kw == "" then return true end   -- any tool = rod
    return tool.Name:lower():find(kw, 1, true) ~= nil
end

-- Returns the current equipped rod (Tool), or nil
local function getEquippedRod()
    local char = LP.Character
    if not char then return nil end
    local tool = char:FindFirstChildWhichIsA("Tool")
    return (tool and isRod(tool)) and tool or nil
end

