local function Clean(obj)
    if obj:IsA("BasePart") then
        obj.Material = Enum.Material.SmoothPlastic
        obj.CastShadow = false
    elseif obj:IsA("Texture") or obj:IsA("Decal") then
        obj:Destroy()
    end
end

Tabs.Performance:Button({
    Title = "Boost Performance (Remove Textures)",
    Callback = function()
        for _,o in pairs(workspace:GetDescendants()) do
            Clean(o)
        end
        WindUI:Notify({Title="Boosted", Content="Textures removed.", Duration=3})
    end
})

-- [[ ENGINE ]]
local waterPlatform = Instance.new("Part", workspace)
waterPlatform.Size = Vector3.new(7, 1, 7)
waterPlatform.Transparency = 1
waterPlatform.Anchored = true
waterPlatform.CanCollide = true

LocalPlayer.Idled:Connect(function()
    VirtualUser:CaptureController(); VirtualUser:ClickButton2(Vector2.new())
end)

LocalPlayer.Backpack.ChildAdded:Connect(function(item)
    if item:IsA("Tool") and FlowConfig.WebhookURL ~= "" then
        task.wait(0.6)
        local rar = item:GetAttribute("rarity") or "Common"
        if FlowConfig.WebhookFilters[rar] then
            local data = {["embeds"]={{["title"]="🎣 Flow Hub Catch!",["color"]=3447003,["fields"]={{["name"]="Fish",["value"]=item.Name,["inline"]=true},{["name"]="Rarity",["value"]=rar,["inline"]=true}}}}}
            pcall(function() request({Url=FlowConfig.WebhookURL, Method="POST", Headers={["Content-Type"]="application/json"}, Body=HttpService:JSONEncode(data)}) end)
        end
    end
end)

RunService.Heartbeat:Connect(function()
    local char = LocalPlayer.Character
    if char and char:FindFirstChild("Humanoid") then
        local root = char:FindFirstChild("HumanoidRootPart")
        
        if FlowConfig.WalkWater and root and root.Position.Y < 8 then
            waterPlatform.CFrame = root.CFrame * CFrame.new(0, -3.5, 0)
        else
            waterPlatform.CFrame = CFrame.new(0, 99999, 0)
        end

        if FlowConfig.AntiDrown then
            local drownScript = char:FindFirstChild("Drown") or char:FindFirstChild("Oxygen")
            if drownScript and drownScript:IsA("LocalScript") then
                drownScript.Enabled = false
            end
        end

        if FlowConfig.AutoEquip and not char:FindFirstChildWhichIsA("Tool") then
            local t = LocalPlayer.Backpack:FindFirstChildWhichIsA("Tool")
            if t and (t.Name:lower():find("rod") or t.Name:lower():find("kail")) then
                t.Parent = char
            end
        end
    end

    if FlowConfig.Streamer or FlowConfig.AntiStaff then
        for _,p in pairs(Players:GetPlayers()) do
            if p ~= LocalPlayer then
                if FlowConfig.AntiStaff and (p.Name:lower():find("admin") or p.Name:lower():match("staff")) then
                    LocalPlayer:Kick("Staff Detected")
                end
                
                if FlowConfig.Streamer and p.Character then
                    for _,v in pairs(p.Character:GetDescendants()) do
                        if v:IsA("TextLabel") and (v.Name:lower() == "namelabel" or v.Name:lower() == "name") then
                            v.Text = "Hidden"
                        elseif v:IsA("BillboardGui") and v.Name:lower():match("name") then
                            v.Enabled = false
                        end
                    end
                end
            end
        end
    end
end)

task.spawn(function()
    while true do
        task.wait(0.5)
        if FlowConfig.Farming and LocalPlayer.Character then
            pcall(function()
                local tool = LocalPlayer.Character:FindFirstChildWhichIsA("Tool")
                if tool then
                    local root = LocalPlayer.Character.HumanoidRootPart
                    local castPos = root.Position + (root.CFrame.LookVector * 15)
                    AnimController:Play("PrepareCast", 0.1)
                    FishingSystem.CastReplication:FireServer(castPos, root.Position, tool.Name, 99.5)
                    task.wait(1.5); FishingSystem.PrecalcFish:InvokeServer(); task.wait(0.5)
                    FishingSystem.ReplicatePullAlert:FireServer("rbxassetid://76503247176490")
                    task.wait(FlowConfig.Delay)
                    FishingSystem.FishGiver:FireServer({["hookPosition"]=castPos})
                    task.wait(1.5); FishingSystem.CleanupCast:FireServer()
                end
            end)
        end
        
        if FlowConfig.AutoSell then
            pcall(function()
                if FishingSystem:FindFirstChild("SellFish") then
                    FishingSystem.SellFish:InvokeServer()
                end
            end)
        end
    end
end)
