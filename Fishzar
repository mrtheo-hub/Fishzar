-- [[ 3. WEBHOOK LOGIC (FIXED) ]]
local function SendWebhook(data, isTest)
    if _G.WebhookURL == "" or not _G.WebhookURL:match("discord.com/api/webhooks") then return end
    
    local content = {
        ["embeds"] = {{
            ["title"] = isTest and "✅ Webhook Connected!" or "🎣 Ikan Tertangkap!",
            ["description"] = isTest and "Koneksi Berhasil! Script siap mengirim data ikan." or nil,
            ["color"] = isTest and 65280 or 3447003,
            ["fields"] = not isTest and {
                {["name"] = "Nama", ["value"] = data.fishId, ["inline"] = true},
                {["name"] = "Rarity", ["value"] = data.rarity, ["inline"] = true},
                {["name"] = "Berat", ["value"] = data.weight .. " kg", ["inline"] = true}
            } or nil,
            ["footer"] = {["text"] = "DapzX Atomic | " .. os.date("%X")}
        }}
    }

    local success, err = pcall(function()
        return (http_request or request or syn.request)({
            Url = _G.WebhookURL,
            Method = "POST",
            Headers = {["Content-Type"] = "application/json"},
            Body = HttpService:JSONEncode(content)
        })
    end)
    if not success then warn("Webhook Failed: "..tostring(err)) end
end

