local function serverHop(targetLow)
    local x = {}
    local raw = game:HttpGet("https://games.roblox.com/v1/games/" .. game.PlaceId .. "/servers/Public?sortOrder="..(targetLow and "Asc" or "Desc").."&limit=100")
    local decode = HttpService:JSONDecode(raw)
    for _,v in pairs(decode.data) do
        if v.playing and v.playing ~= v.maxPlayers and v.id ~= game.JobId then table.insert(x, v.id) end
    end
    if #x > 0 then TeleportService:TeleportToPlaceInstance(game.PlaceId, x[math.random(1, #x)], LocalPlayer) end
end

