-- [[ DAPZX ATOMIC | FISHZAR V9.0.0 - UNIFIED ]]
local RunService = game:GetService("RunService")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Players = game:GetService("Players")
local HttpService = game:GetService("HttpService")
local LocalPlayer = Players.LocalPlayer
local FishingSystem = ReplicatedStorage:WaitForChild("FishingSystem")
local FishingModules = FishingSystem:WaitForChild("FishingModules")
local AnimController = require(FishingModules:WaitForChild("AnimationController"))

_G.Version = "v9.0.0"
_G.FarmingActive = false
_G.AutoSellActive = false
_G.WalkOnWater = false
_G.AntiAFK = false
_G.AntiDrown = false
_G.AutoEquip = false
_G.StreamerMode = false
_G.AntiStaff = false
_G.SettingsDelay = 3.0

-- [[ 1. UI SETUP ]]
local WindUI = loadstring(game:HttpGet("https://raw.githubusercontent.com/Footagesus/WindUI/main/dist/main.lua"))()
local Window = WindUI:CreateWindow({Title = "DapzX Atomic | Fishzar ".._G.Version, Icon = "solar:atom-bold", Size = UDim2.fromOffset(580, 460)})
Window:Tag({Title = "Exec: "..(identifyexecutor() or "Unknown"), Color = Color3.fromHex("#06FFA5")})

-- [[ 2. TAB: MAIN ]]
local MainTab = Window:Tab({Title = "Main", Icon = "solar:home-smile-bold"})
MainTab:Section({Title = "DapzX Atomic System © 2026"})
MainTab:Section({Title = "Hak Cipta: Seluruh kode ini dilindungi undang-undang. Dilarang memperjualbelikan atau mendistribusikan ulang tanpa izin dari DapzX Team."})
MainTab:Button({Title = "Copy Discord Server", Callback = function() setclipboard("https://discord.gg/getsades") end})

-- [[ 3. TAB: PLAYER ]]
local PlayerTab = Window:Tab({Title = "Player", Icon = "solar:user-bold"})
PlayerTab:Toggle({Title = "Walk on Water", Callback = function(s) _G.WalkOnWater = s end})
PlayerTab:Toggle({Title = "Anti AFK", Callback = function(s) _G.AntiAFK = s end})
PlayerTab:Toggle({Title = "Anti Drown (Infinite Oxygen)", Callback = function(s) _G.AntiDrown = s end})
PlayerTab:Toggle({Title = "Auto Equip Rod", Callback = function(s) _G.AutoEquip = s end})

-- [[ 4. TAB: FISHING ]]
local FTab = Window:Tab({Title = "Fishing", Icon = "solar:fishing-rod-bold"})
FTab:Toggle({Title = "Auto Farm", Callback = function(s) _G.FarmingActive = s end})
FTab:Input({Title = "Settings Delay (Detik)", Placeholder = "3.0", Callback = function(v) _G.SettingsDelay = tonumber(v) or 3 end})

-- [[ 5. TAB: SHOP & TELEPORT ]]
local ShopTab = Window:Tab({Title = "Shop", Icon = "solar:bag-bold"})
ShopTab:Toggle({Title = "Auto Sell", Callback = function(s) _G.AutoSellActive = s end})

local TTab = Window:Tab({Title = "Teleport", Icon = "solar:map-point-wave-bold"})
local Islands = {["Nelayan"] = Vector3.new(-34, 14, 256), ["Aquarist"] = Vector3.new(-2032, 13, -833), ["Crystaliz"] = Vector3.new(203, 13, -2614), ["Megalodon"] = Vector3.new(3125, 9, -1713)}
for n, p in pairs(Islands) do TTab:Button({Title = n, Callback = function() if LocalPlayer.Character then LocalPlayer.Character.HumanoidRootPart.CFrame = CFrame.new(p) end end}) end

-- [[ 6. TAB: UTILITIES & PERFORMANCE ]]
local UTab = Window:Tab({Title = "Utilities", Icon = "solar:shield-keyhole-bold"})
UTab:Toggle({Title = "Streamer Mode (Hide Nametag)", Callback = function(s) _G.StreamerMode = s end})
UTab:Toggle({Title = "Anti Staff", Callback = function(s) _G.AntiStaff = s end})
local PingL = UTab:Section({Title = "Ping: Loading..."})
local FPSL = UTab:Section({Title = "FPS: Loading..."})

local PTab = Window:Tab({Title = "Performance", Icon = "solar:bolt-bold"})
PTab:Button({Title = "FPS Booster (Clean Textures)", Callback = function() 
    for _,v in pairs(workspace:GetDescendants()) do if v:IsA("Decal") or v:IsA("Texture") then v:Destroy() end end 
end})

-- [[ 7. BACKGROUND LOOPS ]]
-- Real-time Stats
task.spawn(function()
    while task.wait(1) do
        PingL:SetTitle("Ping: " .. math.floor(game:GetService("Stats").Network.ServerStatsItem["Data Ping"]:GetValue()) .. "ms")
        FPSL:SetTitle("FPS: " .. math.floor(workspace:GetRealTimePhysicsFPS()))
    end
end)

-- Walk on Water & Streamer Mode
RunService.RenderStepped:Connect(function()
    if _G.WalkOnWater and LocalPlayer.Character then
        local p = LocalPlayer.Character.HumanoidRootPart.Position
        if p.Y < 5 then LocalPlayer.Character.HumanoidRootPart.CFrame = CFrame.new(p.X, 5.5, p.Z) end
    end
    if _G.StreamerMode and LocalPlayer.Character then
        local h = LocalPlayer.Character:FindFirstChild("Head")
        if h and h:FindFirstChild("Nametag") then h.Nametag.Enabled = false end
    end
end)

-- Anti Drown (Infinite Oxygen)
task.spawn(function()
    while task.wait(1) do
        if _G.AntiDrown and LocalPlayer.Character:FindFirstChild("Oxygen") then LocalPlayer.Character.Oxygen.Value = 100 end
    end
end)

-- Auto Equip
task.spawn(function()
    while task.wait(2) do
        if _G.AutoEquip and LocalPlayer.Character and not LocalPlayer.Character:FindFirstChildWhichIsA("Tool") then
            local rod = LocalPlayer.Backpack:FindFirstChildWhichIsA("Tool")
            if rod then LocalPlayer.Character.Humanoid:EquipTool(rod) end
        end
    end
end)

-- [[ 8. LOCKED MANCING METHOD (V5.5.0) ]]
task.spawn(function()
    while true do
        task.wait(0.5)
        if _G.FarmingActive and LocalPlayer.Character then
            pcall(function()
                local char = LocalPlayer.Character
                local root = char.HumanoidRootPart
                local tool = char:FindFirstChildWhichIsA("Tool")
                if tool then
                    local castPos = root.Position + (root.CFrame.LookVector * 15) + Vector3.new(0, -6, 0)
                    AnimController:Play("PrepareCast", 0.1)
                    FishingSystem.CastReplication:FireServer(castPos, root.Position, tool.Name, 99.5)
                    task.wait(1.5)
                    FishingSystem.PrecalcFish:InvokeServer()
                    task.wait(0.5)
                    FishingSystem.ReplicatePullAlert:FireServer("rbxassetid://76503247176490")
                    task.wait(_G.SettingsDelay)
                    FishingSystem.FishGiver:FireServer({ ["hookPosition"] = castPos })
                    task.wait(0.3)
                    FishingSystem.CleanupCast:FireServer()
                    AnimController:Play("EquippedAnimation", 0.3)
                    task.wait(1.5)
                end
            end)
        end
    end
end)
