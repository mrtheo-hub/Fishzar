-- 1. CLEANUP & INITIALIZATION
for _, v in pairs(game:GetService("CoreGui"):GetChildren()) do
    if v.Name == "FlowHub_Auth" or v.Name == "WindUI" then v:Destroy() end
end

local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local CoreGui = game:GetService("CoreGui")

local Version = "2.2.0 (Stable)"
local Executor = (identifyexecutor and identifyexecutor()) or "Unknown Mobile"
local ValidKeys = {"FlowHub", "Dapz", "Mon", "Theo"}
local KeyFile = "FlowHub_Auth.txt"

local function SaveK(k) writefile(KeyFile, k) end
local function ReadK() return isfile(KeyFile) and readfile(KeyFile) or "" end

