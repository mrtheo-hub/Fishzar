-- [ WEBHOOK TAB ]
Tabs.Webhook:Input({ Title = "Webhook URL", Placeholder = "Paste URL...", Callback = function(v) FlowConfig.WebhookURL = v end })
for name, val in pairs(FlowConfig.WebhookFilters) do
    Tabs.Webhook:Toggle({ Title = "Filter: " .. name, Default = val, Callback = function(v) FlowConfig.WebhookFilters[name] = v end })
end

-- [ CORE LOGIC ]
LocalPlayer.Backpack.ChildAdded:Connect(function(item)
    if item:IsA("Tool") and not item.Name:lower():find("rod") then
        task.spawn(function()
            task.wait(2) -- Delay agar atribut ter-replicate dengan sempurna
            local rar = item:GetAttribute("Rarity") or item:GetAttribute("rarity") or "Common"
            if FlowConfig.WebhookFilters[rar] then
                sendWebhook("🎣 New Catch!", "Fish caught successfully!", {
                    {["name"] = "Fish", ["value"] = item.Name, ["inline"] = true},
                    {["name"] = "Rarity", ["value"] = rar, ["inline"] = true}
                }, 0x00FF00)
            end
        end)
    end
end)

-- Disconnect Monitor
game:BindToClose(function()
    sendWebhook("⚠️ Disconnected", "Client has disconnected from the game.", nil, 0xFF0000)
end)

-- Main Loop
task.spawn(function()
    while task.wait(0.5) do
        if FlowConfig.Farming and LocalPlayer.Character and FishingSystem then
            pcall(function()
                local tool = LocalPlayer.Character:FindFirstChildWhichIsA("Tool")
                if tool and (tool.Name:lower():find("rod") or tool.Name:lower():find("kail")) then
                    local root = LocalPlayer.Character.HumanoidRootPart
                    local pos = root.Position + (root.CFrame.LookVector * 15)
                    FishingSystem.CastReplication:FireServer(pos, root.Position, tool.Name, 99.5)
                    task.wait(1.5); FishingSystem.PrecalcFish:InvokeServer(); task.wait(0.5)
                    FishingSystem.ReplicatePullAlert:FireServer("rbxassetid://76503247176490")
                    task.wait(FlowConfig.Delay)
                    FishingSystem.FishGiver:FireServer({["hookPosition"]=pos})
                    task.wait(1.5); FishingSystem.CleanupCast:FireServer()
                end
            end)
        end
    end
end)
