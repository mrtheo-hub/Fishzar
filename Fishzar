-- [[ CORE ENGINE LOOPS ]]

-- Loop 1: Stats & Security
task.spawn(function()
    while task.wait(1) do
        pcall(function()
            -- Update UI Stats
            local ping = math.floor(Stats.Network.ServerStatsItem["Data Ping"]:GetValue())
            local fps = math.floor(workspace:GetRealTimePhysicsFPS())
            PingL:SetTitle("Ping: "..ping.."ms")
            FPSL:SetTitle("FPS: "..fps)

            -- Anti AFK (Fixed Method)
            if _G.Config.AntiAFK then
                VirtualUser:CaptureController()
                VirtualUser:ClickButton2(Vector2.new())
            end

            -- Anti Staff (Improved Logic)
            if _G.Config.AntiStaff then
                for _, p in pairs(Players:GetPlayers()) do
                    if p ~= LocalPlayer and (p:GetRankInGroup(0) > 10 or p.Name:lower():find("admin") or p.Name:lower():find("staff")) then
                        LocalPlayer:Kick("Security Breach: Staff Detected ("..p.Name..")")
                    end
                end
            end
        end)
    end
end)

-- Loop 2: Fishing Logic (Metode Tidak Disentuh)
task.spawn(function()
    while true do
        task.wait(0.5)
        if _G.Config.Farming and LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
            pcall(function()
                local tool = LocalPlayer.Character:FindFirstChildWhichIsA("Tool")
                if tool then
                    local root = LocalPlayer.Character.HumanoidRootPart
                    local castPos = root.Position + (root.CFrame.LookVector * 15) + Vector3.new(0, -6, 0)
                    
                    AnimController:Play("PrepareCast", 0.1)
                    FishingSystem.CastReplication:FireServer(castPos, root.Position, tool.Name, 99.5)
                    
                    task.wait(1.5 + _G.Config.Delay)
                    
                    FishingSystem.FishGiver:FireServer({ ["hookPosition"] = castPos })
                    task.wait(1.5)
                    FishingSystem.CleanupCast:FireServer()
                end
            end)
        end
    end
end)
