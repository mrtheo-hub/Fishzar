local ValidKeys = {"FlowHub", "Dapz", "Mon", "Theo"}
local KeyFile = "AtomicFlow_Key.txt"

local function SaveKey(key) writefile(KeyFile, key) end
local function ReadKey() return isfile(KeyFile) and readfile(KeyFile) or "" end

