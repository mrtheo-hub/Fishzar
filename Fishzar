-- [[ 1. WEBHOOK SYSTEM (FIXED) ]]
local function SendWebhook(item)
    if _G.Config.Webhook == "" then return end
    local rarity = item:GetAttribute("rarity") or "Common"
    if not _G.Config.RarityFilter[rarity] then return end
    
    local payload = {
        ["embeds"] = {{
            ["title"] = "🎣 Ikan Tertangkap!",
            ["description"] = "Ikan: **" .. item.Name .. "**\nRarity: **" .. rarity .. "**",
            ["color"] = 16711680,
            ["footer"] = {["text"] = "DapzX Atomic System © 2026"}
        }}
    }
    pcall(function() (http_request or request)({Url=_G.Config.Webhook, Method="POST", Headers={["Content-Type"]="application/json"}, Body=HttpService:JSONEncode(payload)}) end)
end

LocalPlayer.Backpack.ChildAdded:Connect(function(i) if i:IsA("Tool") then task.wait(0.5); SendWebhook(i) end end)

