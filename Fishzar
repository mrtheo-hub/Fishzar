local function serverHop(lowPop)
    local ok, err = pcall(function()
        local order = lowPop and "Asc" or "Desc"
        local raw   = game:HttpGet(
            "https://games.roblox.com/v1/games/"..game.PlaceId
            .."/servers/Public?sortOrder="..order.."&limit=100")
        local list  = Http:JSONDecode(raw).data or {}
        local valid = {}
        for _, s in ipairs(list) do
            if s.id and s.playing and s.maxPlayers
            and s.playing < s.maxPlayers
            and s.id ~= game.JobId then
                valid[#valid+1] = s.id
            end
        end
        if #valid == 0 then N("Server Hop","No suitable servers found.",3) return end
        TS:TeleportToPlaceInstance(game.PlaceId, valid[math.random(1,#valid)], LP)
    end)
    if not ok then N("Error", tostring(err), 5) end
end

