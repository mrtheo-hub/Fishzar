local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local HttpService = game:GetService("HttpService")
local LocalPlayer = Players.LocalPlayer

-- LOAD FLUENT UI (Sangat Stabil)
local Fluent = loadstring(game:HttpGet("https://github.com/dawid-scripts/Fluent/releases/latest/download/main.lua"))()
local SaveManager = loadstring(game:HttpGet("https://raw.githubusercontent.com/dawid-scripts/Fluent/master/Addons/SaveManager.lua"))()
local InterfaceManager = loadstring(game:HttpGet("https://raw.githubusercontent.com/dawid-scripts/Fluent/master/Addons/InterfaceManager.lua"))()

local Window = Fluent:CreateWindow({
    Title = "DapzX Atomic | Fishzar",
    SubTitle = "v2.0",
    TabWidth = 160,
    Size = UDim2.fromOffset(580, 460),
    Acrylic = true,
    Theme = "Dark",
    MinimizeKey = Enum.KeyCode.LeftControl
})

-- GLOBALS
_G.FarmingActive = false
_G.AutoSellActive = false
_G.WebhookURL = ""
_G.MinigameDelay = 3

-- UTILITY
local function SendWebhook(title, desc)
    if _G.WebhookURL == "" then return end
    pcall(function()
        (http_request or request or syn.request)({
            Url = _G.WebhookURL,
            Method = "POST",
            Headers = {["Content-Type"] = "application/json"},
            Body = HttpService:JSONEncode({embeds = {{title = title, description = desc, color = 65445}}})
        })
    end)
end

-- TABS
local Tabs = {
    Fishing = Window:AddTab({ Title = "Fishing", Icon = "fishing-rod" }),
    Shop = Window:AddTab({ Title = "Shop", Icon = "shopping-cart" }),
    Integration = Window:AddTab({ Title = "Integration", Icon = "webhook" }),
    Teleport = Window:AddTab({ Title = "Teleport", Icon = "map-pin" })
}

-- FISHING TAB
Tabs.Fishing:AddToggle("AutoFarm", {Title = "Enable Auto Farm", Default = false, Callback = function(s) _G.FarmingActive = s end})
Tabs.Fishing:AddSlider("DelaySlider", {Title = "Farming Delay", Min = 0.5, Max = 5, Default = 3, Callback = function(v) _G.MinigameDelay = v end})

-- SHOP TAB
Tabs.Shop:AddToggle("AutoSell", {Title = "Enable Auto Sell", Default = false, Callback = function(s) _G.AutoSellActive = s end})

-- INTEGRATION TAB
Tabs.Integration:AddInput("WebhookInput", {
    Title = "Discord Webhook URL",
    Default = "",
    Placeholder = "Paste URL di sini...",
    Callback = function(v) _G.WebhookURL = v end
})

Tabs.Integration:AddButton({
