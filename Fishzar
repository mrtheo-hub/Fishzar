-- Rarity colors for embed
local RAR_COLORS = {
    Common   = 0xAAAAAA,
    Uncommon = 0x44CC44,
    Rare     = 0x4499FF,
    Epic     = 0xAA44FF,
    Legendary= 0xFFAA00,
    Secret   = 0xFF2255,
}

local function getRarity(item)
    local r = item:GetAttribute("Rarity")
           or item:GetAttribute("rarity")
    if not r and item:FindFirstChild("Rarity") then
        r = item.Rarity.Value
    end
    -- Sometimes it's a StringValue child
    if not r then
        local rv = item:FindFirstChild("Rarity") or item:FindFirstChild("rarity")
        if rv and rv:IsA("StringValue") then r = rv.Value end
    end
    return tostring(r or "Common")
end

