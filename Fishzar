-- Bug 2: Webhook Embed Fix (Accurate Rarity)
local function sendCatch(name, rarity)
    if FlowConfig.WebhookURL == "" then return end
    local color = RarityColors[rarity] or 0xFFFFFF
    local data = {
        ["username"] = "Flow Hub Logger",
        ["embeds"] = {{
            ["title"] = "🎣 New Legendary Catch!",
            ["color"] = color,
            ["fields"] = {
                {["name"] = "👤 Account", ["value"] = "||"..LocalPlayer.Name.."||", ["inline"] = true},
                {["name"] = "🐟 Fish Name", ["value"] = "**"..name.."**", ["inline"] = true},
                {["name"] = "✨ Rarity", ["value"] = "`"..rarity.."`", ["inline"] = true},
                {["name"] = "🆔 Server ID", ["value"] = "`"..game.JobId.."`", ["inline"] = false}
            },
            ["footer"] = {["text"] = "Flow Hub "..Version.." | "..os.date("%X")},
            ["timestamp"] = os.date("!%Y-%m-%dT%H:%M:%SZ")
        }}
    }
    pcall(function() request({Url = FlowConfig.WebhookURL, Method = "POST", Headers = {["Content-Type"] = "application/json"}, Body = HttpService:JSONEncode(data)}) end)
end

