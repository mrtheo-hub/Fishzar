        if not root then continue end

        _casting = true
        pcall(function()
            local castPos = root.Position + root.CFrame.LookVector * 15

            if Anim then pcall(function() Anim:Play("PrepareCast", 0.1) end) end

            local r1 = getR("CastReplication")
            if r1 then r1:FireServer(castPos, root.Position, tool.Name, 99.5) end
