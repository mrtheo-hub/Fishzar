local RunService = game:GetService("RunService")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Players = game:GetService("Players")
local HttpService = game:GetService("HttpService")
local VirtualUser = game:GetService("VirtualUser")
local LocalPlayer = Players.LocalPlayer

-- LOAD WINDUI
local WindUI = loadstring(game:HttpGet("https://raw.githubusercontent.com/Footagesus/WindUI/main/dist/main.lua"))()

-- [[ CONFIG ]]
_G.FarmingActive = false
_G.WalkOnWater = false
_G.WebhookURL = ""
_G.FilterRarity = { ["Rare"] = true, ["Epic"] = true, ["Legendary"] = true, ["Secret"] = true }

-- [[ ANTI AFK & WALK ON WATER ]]
-- Anti-AFK
LocalPlayer.Idled:Connect(function()
    VirtualUser:CaptureController()
    VirtualUser:ClickButton2(Vector2.new())
end)

-- Walk on Water (Membuat Part transparan di bawah air)
local WaterPlatform
RunService.RenderStepped:Connect(function()
    if _G.WalkOnWater then
        if not WaterPlatform then
            WaterPlatform = Instance.new("Part", workspace)
            WaterPlatform.Anchored = true
            WaterPlatform.Transparency = 1
            WaterPlatform.Size = Vector3.new(100, 1, 100)
        end
        local pos = LocalPlayer.Character and LocalPlayer.Character.HumanoidRootPart.Position
        if pos then WaterPlatform.Position = Vector3.new(pos.X, 4, pos.Z) end
    elseif WaterPlatform then
        WaterPlatform:Destroy()
        WaterPlatform = nil
    end
end)

-- [[ UI ]]
local Window = WindUI:CreateWindow({Title = "Flow Hub | Fishzar", Icon = "solar:atom-bold", Size = UDim2.fromOffset(580, 460)})

-- TAB: FISHING
local FishingTab = Window:Tab({Title = "Fishing", Icon = "solar:cursor-square-bold"})
FishingTab:Section({Title = "Auto Farm"}):Toggle({Title = "Enable Auto Farm", Callback = function(s) _G.FarmingActive = s end})
FishingTab:Section({Title = "Movement"}):Toggle({Title = "Walk on Water", Callback = function(s) _G.WalkOnWater = s end})

-- TAB: TELEPORT
local TeleportTab = Window:Tab({Title = "Teleport", Icon = "solar:map-point-wave-bold"})
local Islands = {
    ["Pulau Nelayan"] = Vector3.new(-34, 14, 256),
    ["Pulau Aquarist"] = Vector3.new(-2032, 13, -833),
    ["Megalodon Zone"] = Vector3.new(3125, 9, -1713)
}
for name, pos in pairs(Islands) do
    TeleportTab:Section({Title = name}):Button({Title = "Teleport", Callback = function() 
        if LocalPlayer.Character then LocalPlayer.Character.HumanoidRootPart.CFrame = CFrame.new(pos) end 
    end})
end

-- TAB: INTEGRATION
local IntegrationTab = Window:Tab({Title = "Integration", Icon = "solar:settings-bold"})
IntegrationTab:Section({Title = "Webhook URL"}):Input({Title = "URL", Callback = function(v) _G.WebhookURL = v end})
IntegrationTab:Section({Title = "Filters"}):Toggle({Title = "Enable Legendary", Callback = function(s) _G.FilterRarity["Legendary"] = s end})

-- [[ MAIN LOOP ]]
task.spawn(function()
    local FishingSystem = ReplicatedStorage:WaitForChild("FishingSystem")
    while true do
        task.wait(1)
        if _G.FarmingActive and LocalPlayer.Character then
            -- Auto Equip Rod
            local hasRod = false
            for _, item in pairs(LocalPlayer.Backpack:GetChildren()) do
                if item:IsA("Tool") and item:FindFirstChild("Handle") then
                    LocalPlayer.Character.Humanoid:EquipTool(item)
                    hasRod = true
                    break
                end
            end
            
            if hasRod then
                local tool = LocalPlayer.Character:FindFirstChildWhichIsA("Tool")
                local root = LocalPlayer.Character.HumanoidRootPart
                local castPos = root.Position + (root.CFrame.LookVector * 15)
                
                FishingSystem.CastReplication:FireServer(castPos, root.Position, tool.Name, 99.5)
                task.wait(2)
                FishingSystem.FishGiver:FireServer({["hookPosition"] = castPos})
                FishingSystem.CleanupCast:FireServer()
                
                -- Webhook check (Simpel)
                task.wait(7) -- Delay 7 detik per ikan
            end
        end
    end
end)
