-- [CORE ENGINE]
task.spawn(function()
    while task.wait(0.5) do
        if FlowConfig.Farming and LocalPlayer.Character and FishingSystem then
            pcall(function()
                local tool = LocalPlayer.Character:FindFirstChildWhichIsA("Tool")
                if tool and tool.Name:lower():find("rod") then
                    local root = LocalPlayer.Character.HumanoidRootPart
                    local pos = root.Position + (root.CFrame.LookVector * 15)
                    FishingSystem.CastReplication:FireServer(pos, root.Position, tool.Name, 100)
                    task.wait(1.5)
                    FishingSystem.FishGiver:FireServer({["hookPosition"]=pos})
                    task.wait(1)
                    FishingSystem.CleanupCast:FireServer()
                end
            end)
        end
        -- Auto Features
        local char = LocalPlayer.Character
        if char then
            if FlowConfig.AutoSell then pcall(function() ReplicatedStorage:FindFirstChild("SellFish", true):InvokeServer() end) end
            if FlowConfig.AntiDrown then for _, v in pairs(char:GetDescendants()) do if v.Name == "Oxygen" then v.Value = 100 end end end
        end
    end
end)
