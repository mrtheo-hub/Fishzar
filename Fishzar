-- [[ DAPZX ATOMIC | FISHZAR V13.0.0 - FIXED ALL ]]
local RunService = game:GetService("RunService")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local Stats = game:GetService("Stats")
local FishingSystem = ReplicatedStorage:WaitForChild("FishingSystem")
local AnimController = require(FishingSystem.FishingModules:WaitForChild("AnimationController"))

-- GLOBAL SETTINGS
_G.FarmingActive = false; _G.WalkOnWater = false; _G.AntiDrown = false; _G.StreamerMode = false; _G.AntiStaff = false; _G.SettingsDelay = 3.0

-- [[ 1. SECURITY & UTILITIES (DIPERBAIKI) ]]
local function GetStats()
    local ping = math.floor(Stats.Network.ServerStatsItem["Data Ping"]:GetValue())
    local fps = math.floor(workspace:GetRealTimePhysicsFPS())
    return ping, fps
end

-- Streamer Mode: Hapus semua Nametag secara paksa
RunService.RenderStepped:Connect(function()
    if _G.StreamerMode then
        for _, p in pairs(Players:GetPlayers()) do
            if p.Character and p.Character:FindFirstChild("Head") then
                for _, v in pairs(p.Character.Head:GetChildren()) do
                    if v:IsA("BillboardGui") then v.Enabled = false end
                end
            end
        end
    end
end)

-- Anti Staff (Kick jika Staff/Admin masuk)
Players.PlayerAdded:Connect(function(p)
    if _G.AntiStaff and (p:GetRankInGroup(game.CreatorId) > 0 or p.Name:lower():find("admin") or p.Name:lower():find("staff")) then
        LocalPlayer:Kick("Security Breach: Staff detected")
    end
end)

-- [[ 2. UI & TAB SETUP ]]
local WindUI = loadstring(game:HttpGet("https://raw.githubusercontent.com/Footagesus/WindUI/main/dist/main.lua"))()
local Window = WindUI:CreateWindow({Title = "DapzX Atomic V13", Icon = "solar:atom-bold", Size = UDim2.fromOffset(580, 460)})

local MainTab = Window:Tab({Title = "Main", Icon = "solar:home-smile-bold"})
MainTab:Section({Title = "DapzX Atomic System © 2026"})
MainTab:Button({Title = "Copy Discord", Callback = function() setclipboard("https://discord.gg/getsades") end})

local PlayerTab = Window:Tab({Title = "Player", Icon = "solar:user-bold"})
PlayerTab:Toggle({Title = "Walk on Water", Callback = function(s) _G.WalkOnWater = s end})
PlayerTab:Toggle({Title = "Anti Drown", Callback = function(s) _G.AntiDrown = s end})

local FTab = Window:Tab({Title = "Fishing", Icon = "solar:fishing-rod-bold"})
FTab:Toggle({Title = "Auto Farm", Callback = function(s) _G.FarmingActive = s end})
FTab:Input({Title = "Settings Delay", Placeholder = "3.0", Callback = function(v) _G.SettingsDelay = tonumber(v) or 3 end})

local UTab = Window:Tab({Title = "Utilities", Icon = "solar:shield-keyhole-bold"})
UTab:Toggle({Title = "Streamer Mode", Callback = function(s) _G.StreamerMode = s end})
UTab:Toggle({Title = "Anti Staff", Callback = function(s) _G.AntiStaff = s end})
local PingL = UTab:Section({Title = "Ping: 0ms"})
local FPSL = UTab:Section({Title = "FPS: 0"})

-- [[ 3. FIXED LOOPS ]]
task.spawn(function()
    while task.wait(0.5) do
        local p, f = GetStats()
        PingL:SetTitle("Ping: " .. p .. "ms")
        FPSL:SetTitle("FPS: " .. f)
        
        -- Walk on Water Fix
        if _G.WalkOnWater and LocalPlayer.Character and LocalPlayer.Character.HumanoidRootPart.Position.Y < 5 then
            LocalPlayer.Character.HumanoidRootPart.Velocity = Vector3.new(0, 10, 0)
        end
        
        -- Anti Drown Fix
        if _G.AntiDrown and LocalPlayer.Character then
            LocalPlayer.Character.Humanoid:SetStateEnabled(Enum.HumanoidStateType.Swimming, false)
        end
    end
end)

-- Fishing Loop (LOCKED)
task.spawn(function()
    while true do
        task.wait(0.5)
        if _G.FarmingActive and LocalPlayer.Character then
            pcall(function()
                local tool = LocalPlayer.Character:FindFirstChildWhichIsA("Tool")
                if tool then
                    local castPos = LocalPlayer.Character.HumanoidRootPart.Position + (LocalPlayer.Character.HumanoidRootPart.CFrame.LookVector * 15)
                    AnimController:Play("PrepareCast", 0.1)
                    FishingSystem.CastReplication:FireServer(castPos, LocalPlayer.Character.HumanoidRootPart.Position, tool.Name, 99.5)
                    task.wait(1.5)
                    FishingSystem.PrecalcFish:InvokeServer()
                    task.wait(0.5)
                    FishingSystem.ReplicatePullAlert:FireServer("rbxassetid://76503247176490")
                    task.wait(_G.SettingsDelay)
                    FishingSystem.FishGiver:FireServer({ ["hookPosition"] = castPos })
                    task.wait(1.5); FishingSystem.CleanupCast:FireServer()
                end
            end)
        end
    end
end)
