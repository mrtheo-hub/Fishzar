task.spawn(function()
    while task.wait(0.5) do
        if not FC.Farming  then continue end
        if not FishingSystem then continue end

        local char = LocalPlayer.Character
        if not char then continue end
        local hum = char:FindFirstChildOfClass("Humanoid")
        if not hum or hum.Health <= 0 then continue end
        local tool = char:FindFirstChildWhichIsA("Tool")
        if not tool then continue end
        local tN = tool.Name:lower()
        if not (tN:find("rod") or tN:find("kail") or tN:find("fishing")) then continue end
        local root = char:FindFirstChild("HumanoidRootPart")
        if not root then continue end

        pcall(function()
            local castPos = root.Position + root.CFrame.LookVector * 15
            if AnimController then pcall(function() AnimController:Play("PrepareCast", 0.1) end) end

            local r1 = getRemote("CastReplication")
            if r1 then r1:FireServer(castPos, root.Position, tool.Name, 99.5) end

            task.wait(1.5)
            local r2 = getRemote("PrecalcFish")
            if r2 then pcall(function() r2:InvokeServer() end) end

            task.wait(0.5)
            local r3 = getRemote("ReplicatePullAlert")
            if r3 then r3:FireServer("rbxassetid://76503247176490") end

            task.wait(math.max(FC.Delay, 1))
            local r4 = getRemote("FishGiver")
            if r4 then r4:FireServer({ hookPosition = castPos }) end

            task.wait(1.0)
            local r5 = getRemote("CleanupCast")
            if r5 then r5:FireServer() end
        end)
    end
end)

