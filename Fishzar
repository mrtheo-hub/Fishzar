local function getPlayerLocation()
    if not LocalPlayer.Character or not LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then return "Unknown" end
    local rootPos = LocalPlayer.Character.HumanoidRootPart.Position
    local closest, minDist = "Ocean/Unknown", math.huge
    for name, pos in pairs(Islands) do
        local dist = (rootPos - pos).Magnitude
        if dist < minDist then minDist = dist; closest = name end
    end
    return (minDist < 600) and closest or "Ocean/Unknown"
end

