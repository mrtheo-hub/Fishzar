-- Anti Drown (Safe: Lock Oxygen)
task.spawn(function()
    while task.wait(0.5) do
        if _G.AntiDrown and LocalPlayer.Character then
            local hum = LocalPlayer.Character:FindFirstChild("Humanoid")
            if hum then hum:SetStateEnabled(Enum.HumanoidStateType.Dead, true) end
            -- Memaksa oksigen agar tidak habis
            if LocalPlayer.Character:FindFirstChild("Oxygen") then LocalPlayer.Character.Oxygen.Value = 100 end
        end
    end
end)

-- Auto Equip (Safe)
task.spawn(function()
    while task.wait(1) do
        if _G.AutoEquip and LocalPlayer.Character and not LocalPlayer.Character:FindFirstChildWhichIsA("Tool") then
            local rod = LocalPlayer.Backpack:FindFirstChildWhichIsA("Tool")
            if rod then LocalPlayer.Character.Humanoid:EquipTool(rod) end
        end
    end
end)

-- FISHING LOOP (LOCKED METHOD - JANGAN DIUBAH)
task.spawn(function()
    while true do
        task.wait(0.5)
        if _G.FarmingActive and LocalPlayer.Character then
            pcall(function()
                local char = LocalPlayer.Character
                local root = char.HumanoidRootPart
                local tool = char:FindFirstChildWhichIsA("Tool")
                if tool then
                    local castPos = root.Position + (root.CFrame.LookVector * 15) + Vector3.new(0, -6, 0)
                    AnimController:Play("PrepareCast", 0.1)
                    FishingSystem.CastReplication:FireServer(castPos, root.Position, tool.Name, 99.5)
                    task.wait(1.5)
                    FishingSystem.PrecalcFish:InvokeServer()
                    task.wait(0.5)
                    FishingSystem.ReplicatePullAlert:FireServer("rbxassetid://76503247176490")
                    task.wait(_G.SettingsDelay)
                    FishingSystem.FishGiver:FireServer({ ["hookPosition"] = castPos })
                    task.wait(0.3)
                    FishingSystem.CleanupCast:FireServer()
                    AnimController:Play("EquippedAnimation", 0.3)
                    task.wait(1.5)
                end
            end)
        end
    end
end)
