-- [[ DAPZX ATOMIC | FISHZAR V11.0.0 - RECODED MODULAR ]]
local RunService = game:GetService("RunService")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local Stats = game:GetService("Stats")
local FishingSystem = ReplicatedStorage:WaitForChild("FishingSystem")
local AnimController = require(FishingSystem.FishingModules:WaitForChild("AnimationController"))

-- GLOBAL CONFIG
_G.FarmingActive = false
_G.SettingsDelay = 3.0
_G.WalkOnWater = false
_G.AntiDrown = false
_G.AutoEquip = false
_G.StreamerMode = false

-- [[ 1. MODULAR SYSTEMS ]]
-- Mancing (LOCKED & PROTECTED)
task.spawn(function()
    while true do
        task.wait(0.5)
        if _G.FarmingActive and LocalPlayer.Character then
            pcall(function()
                local tool = LocalPlayer.Character:FindFirstChildWhichIsA("Tool")
                if tool then
                    local root = LocalPlayer.Character.HumanoidRootPart
                    local castPos = root.Position + (root.CFrame.LookVector * 15)
                    AnimController:Play("PrepareCast", 0.1)
                    FishingSystem.CastReplication:FireServer(castPos, root.Position, tool.Name, 99.5)
                    task.wait(1.5); FishingSystem.PrecalcFish:InvokeServer(); task.wait(0.5)
                    FishingSystem.ReplicatePullAlert:FireServer("rbxassetid://76503247176490")
                    task.wait(_G.SettingsDelay)
                    FishingSystem.FishGiver:FireServer({ ["hookPosition"] = castPos })
                    task.wait(1.5); FishingSystem.CleanupCast:FireServer()
                end
            end)
        end
    end
end)

-- Player Utilities (Walk on Water & Anti Drown)
RunService.RenderStepped:Connect(function()
    if _G.WalkOnWater and LocalPlayer.Character then
        local p = LocalPlayer.Character.HumanoidRootPart
        if p.Position.Y < 5 then p.Velocity = Vector3.new(0, 5, 0) end
    end
    if _G.AntiDrown and LocalPlayer.Character:FindFirstChild("Humanoid") then
        LocalPlayer.Character.Humanoid:SetStateEnabled(Enum.HumanoidStateType.Swimming, false)
    end
end)

-- Auto Equip
task.spawn(function()
    while task.wait(2) do
        if _G.AutoEquip and LocalPlayer.Character and not LocalPlayer.Character:FindFirstChildWhichIsA("Tool") then
            local rod = LocalPlayer.Backpack:FindFirstChildWhichIsA("Tool")
            if rod then LocalPlayer.Character.Humanoid:EquipTool(rod) end
        end
    end
end)

-- UI LOADING
local WindUI = loadstring(game:HttpGet("https://raw.githubusercontent.com/Footagesus/WindUI/main/dist/main.lua"))()
local Window = WindUI:CreateWindow({Title = "DapzX Atomic V11", Icon = "solar:atom-bold", Size = UDim2.fromOffset(580, 460)})

-- TAB UI
local MainTab = Window:Tab({Title = "Main", Icon = "solar:home-smile-bold"})
MainTab:Section({Title = "DapzX Atomic System © 2026"})
MainTab:Button({Title = "Copy Discord Link", Callback = function() setclipboard("https://discord.gg/getsades") end})

local PlayerTab = Window:Tab({Title = "Player", Icon = "solar:user-bold"})
PlayerTab:Toggle({Title = "Walk on Water", Callback = function(s) _G.WalkOnWater = s end})
PlayerTab:Toggle({Title = "Anti Drown", Callback = function(s) _G.AntiDrown = s end})
PlayerTab:Toggle({Title = "Auto Equip Rod", Callback = function(s) _G.AutoEquip = s end})

local FTab = Window:Tab({Title = "Fishing", Icon = "solar:fishing-rod-bold"})
FTab:Toggle({Title = "Auto Farm", Callback = function(s) _G.FarmingActive = s end})
FTab:Input({Title = "Settings Delay", Placeholder = "3.0", Callback = function(v) _G.SettingsDelay = tonumber(v) or 3 end})
