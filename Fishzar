local function getRarity(item)
    local r = item:GetAttribute("Rarity") or item:GetAttribute("rarity")
    if not r then
        for _, n in ipairs({"Rarity","rarity","RarityValue"}) do
            local v = item:FindFirstChild(n)
            if v and v.ClassName:find("Value") then r = v.Value; break end
        end
    end
    return tostring(r or "Common")
end

