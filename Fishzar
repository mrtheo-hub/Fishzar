-- Stats Loop
task.spawn(function()
    while task.wait(1) do
        local ping = game:GetService("Stats").Network.ServerStatsItem["Data Ping"]:GetValueString()
        local fps = math.floor(workspace:GetRealTimePhysicsFPS())
        PingLabel:SetTitle("Ping: " .. ping)
        FPSLabel:SetTitle("FPS: " .. fps)
    end
end)

-- Walk on Water (Fixed)
RunService.RenderStepped:Connect(function()
    if _G.WalkOnWater and LocalPlayer.Character then
        local pos = LocalPlayer.Character.HumanoidRootPart.Position
        if pos.Y < 5 then LocalPlayer.Character.HumanoidRootPart.CFrame = CFrame.new(pos.X, 5.5, pos.Z) end
    end
    if _G.AntiDrown and LocalPlayer.Character then
        LocalPlayer.Character:FindFirstChild("Humanoid"):SetStateEnabled(Enum.HumanoidStateType.Dead, false)
        LocalPlayer.Character:FindFirstChild("Humanoid").Oxygen = 100 
    end
    if _G.StreamerMode and LocalPlayer.Character then
        local head = LocalPlayer.Character:FindFirstChild("Head")
        if head and head:FindFirstChild("Nametag") then head.Nametag.Enabled = false end
    end
end)

-- Auto Equip (Fixed)
task.spawn(function()
    while task.wait(2) do
        if _G.AutoEquip and LocalPlayer.Character then
            local tool = LocalPlayer.Character:FindFirstChildWhichIsA("Tool")
            if not tool then
                local rod = LocalPlayer.Backpack:FindFirstChildWhichIsA("Tool")
                if rod then LocalPlayer.Character.Humanoid:EquipTool(rod) end
            end
        end
    end
end)
