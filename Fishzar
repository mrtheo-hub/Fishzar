-- ==========================================
-- 3. MAIN HUB (TAB STABILITY RECODE)
-- ==========================================
function StartFlowHub()
    Screen:Destroy()
    
    -- Load External Fishzar
    task.spawn(function()
        pcall(function()
            loadstring(game:HttpGet("https://raw.githubusercontent.com/mrtheo-hub/Fishzar/refs/heads/main/Fishzar"))()
        end)
    end)

    local WindUI = loadstring(game:HttpGet("https://raw.githubusercontent.com/Footagesus/WindUI/main/dist/main.lua"))()
    local Window = WindUI:CreateWindow({
        Title = "Flow Hub Official",
        Folder = "FlowHub_Data",
        Icon = "solar:waterdrop-bold",
        Size = UDim2.fromOffset(580, 460),
        Search = true
    })

    Window:Tag({ Title = "Exec: " .. Executor, Color = Color3.fromRGB(0, 180, 216) })
    Window:Tag({ Title = "Ver: " .. Version, Color = Color3.new(1,1,1) })

    -- SISTEM RENDER TAB (Anti-Empty)
    local function SafeTab(name, icon, contentFunc)
        local success, tab = pcall(function()
            return Window:Tab({ Title = name, Icon = icon })
        end)
        if success and tab then
            task.spawn(function()
                contentFunc(tab)
            end)
        end
    end

    -- Tab: Main
    SafeTab("Main", "solar:home-bold", function(t)
        t:Section({ Title = "Player Info" })
        t:Section({ Title = "Name: "..LocalPlayer.Name.."\nStatus: Developer", TextSize = 12 })
        t:Button({ Title = "Copy Discord", Callback = function() setclipboard("https://discord.gg/flowhub") end })
    end)

    -- Tab: Teleport
    SafeTab("Teleport", "solar:map-point-wave-bold", function(t)
        t:Section({ Title = "Island Teleports" })
        local Locs = {
            ["Pulau Nelayan"] = Vector3.new(-34, 14, 256),
            ["Gua Crystaliz"] = Vector3.new(171, -142, -4938)
        }
        local names = {} for k,_ in pairs(Locs) do table.insert(names, k) end
        
        t:Dropdown({
            Title = "Select Destination",
            Values = names,
            Callback = function(v)
                if LocalPlayer.Character then
                    LocalPlayer.Character.HumanoidRootPart.CFrame = CFrame.new(Locs[v])
                end
            end
        })
    end)

    -- Tab: Utilities
    SafeTab("Utilities", "solar:settings-bold", function(t)
        t:Section({ Title = "Abilities" })
        getgenv().WoWEnabled = false
        t:Toggle({ Title = "Walk on Water", Callback = function(v) getgenv().WoWEnabled = v end })
        t:Button({ Title = "Rejoin", Callback = function() 
            game:GetService("TeleportService"):Teleport(game.PlaceId, LocalPlayer) 
        end})
    end)
end

-- ==========================================
-- 4. BOOT LOGIC
-- ==========================================
Btn.MouseButton1Click:Connect(function()
    if table.find(ValidKeys, Input.Text) then
        SaveK(Input.Text)
        StartFlowHub()
    else
        LocalPlayer:Kick("Flow Hub: Key Salah!")
    end
end)

local saved = ReadK()
if table.find(ValidKeys, saved) then
    Input.Text = saved
    task.wait(0.5)
    StartFlowHub()
end
