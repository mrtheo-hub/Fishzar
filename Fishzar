-- Walk on Water Physics
local WaterPart = Instance.new("Part")
WaterPart.Size = Vector3.new(10, 1, 10)
WaterPart.Anchored = true
WaterPart.Transparency = 1
WaterPart.CanCollide = false
WaterPart.Parent = workspace

task.spawn(function()
    while _G.ScriptRunning do
        task.wait()
        if _G.WalkOnWater and LocalPlayer.Character then
            local hrp = LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
            if hrp then
                WaterPart.CanCollide = true
                WaterPart.CFrame = CFrame.new(hrp.Position.X, 13.5, hrp.Position.Z) -- Sesuaikan 13.5 dengan tinggi air game
            end
        else
            WaterPart.CanCollide = false
        end
    end
end)

-- Main Logic Loop
task.spawn(function()
    local FishingSystem = ReplicatedStorage:WaitForChild("FishingSystem", 10)
    
    while _G.ScriptRunning do
        task.wait(0.5)

        -- Anti Drown Aggressive
        if _G.AntiDrown and LocalPlayer.Character then
            for _, v in pairs(LocalPlayer.Character:GetDescendants()) do
                if v:IsA("LocalScript") and (v.Name:lower():match("drown") or v.Name:lower():match("oxygen")) then
                    v.Disabled = true
                end
            end
            local ox = LocalPlayer.Character:FindFirstChild("Oxygen") or LocalPlayer.Character:FindFirstChild("Breath")
            if ox then ox.Value = 100 end
        end

        -- Auto Sell Logic
        if _G.AutoSellActive and FishingSystem then
            pcall(function()
                local sellEvent = FishingSystem:FindFirstChild("SellFish")
                if sellEvent then
                    local fish = {}
                    for _, i in pairs(LocalPlayer.Backpack:GetChildren()) do table.insert(fish, i) end
                    sellEvent:FireServer("SellAllBatch", fish)
                end
            end)
        end
    end
end)

-- Hook for Webhook Catch Detection
LocalPlayer.Backpack.ChildAdded:Connect(function(child)
    task.wait(0.5)
    local rarity = child:GetAttribute("Rarity") or child:GetAttribute("rarity")
    if rarity and _G.WebhookURL ~= "" then
        SendWebhook(child.Name, tostring(rarity), tostring(child:GetAttribute("Weight") or "0"))
    end
end)

