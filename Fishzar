end)

LocalPlayer.Backpack.ChildAdded:Connect(function(item)
    if item:IsA("Tool") and not item.Name:lower():find("rod") then
        task.spawn(function()
            local foundRarity = "Common"
            local start = tick()
            -- Loop sebentar sampai attribute terbaca (Mencegah salah rarity)
            repeat 
                foundRarity = item:GetAttribute("Rarity") or item:GetAttribute("rarity") or foundRarity
                task.wait(0.2)
            until foundRarity ~= "Common" or (tick() - start) > 2
            
            if FlowConfig.WebhookFilters[foundRarity] then sendCatch(item.Name, foundRarity) end
        end)
    end
end)

