-- ============================================================================
-- THE FORCE LOOP
-- ============================================================================
task.spawn(function()
    while true do
        task.wait(0.7)
        if _G.FarmingActive then
            local char = LocalPlayer.Character
            local root = char and char:FindFirstChild("HumanoidRootPart")
            local tool = char and char:FindFirstChildWhichIsA("Tool")

            if root and tool and FoundCast then
                pcall(function()
                    local castPos = root.Position + (root.CFrame.LookVector * 25)
                    
                    -- Tembak Lemparan (Mencoba 2 metode sekaligus)
                    if FoundCast:IsA("RemoteFunction") then
                        FoundCast:InvokeServer(castPos)
                    else
                        FoundCast:FireServer(castPos, root.Position, tool.Name)
                    end
                    
                    task.wait(1.5) -- Tunggu ikan
                    
                    -- Tembak Menang
                    if FoundWin then
                        if FoundWin:IsA("RemoteFunction") then
                            FoundWin:InvokeServer(true, 100)
                        else
                            FoundWin:FireServer(true, 100)
                        end
                    end
                    
                    task.wait(_G.CatchDelay)
                    
                    -- Tembak Ambil Ikan
                    if FoundCatch then
                        if FoundCatch:IsA("RemoteFunction") then
                            FoundCatch:InvokeServer({["hookPosition"] = castPos})
                        else
                            FoundCatch:FireServer({["hookPosition"] = castPos})
                        end
                    end
                end)
            elseif _G.FarmingActive and not FoundCast then
                WindUI:Notify({Title = "Warning", Content = "Remote tidak ditemukan sama sekali!", Duration = 1})
            end
        end
    end
end)

