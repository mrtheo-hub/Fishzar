-- [[ DAPZX ATOMIC | FISHZAR V3.3.0 (FIXED) ]]
local RunService = game:GetService("RunService")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Players = game:GetService("Players")
local HttpService = game:GetService("HttpService")
local LocalPlayer = Players.LocalPlayer

-- [[ GLOBAL CONFIG ]]
_G.FarmingActive = false
_G.AutoSellActive = false
_G.WebhookURL = ""
_G.FilterRarity = { ["Common"] = false, ["Uncommon"] = false, ["Rare"] = false, ["Epic"] = false, ["Legendary"] = false, ["Secret"] = false }

-- [[ FUNGSI WEBHOOK (FIXED LOGIC) ]]
local function SendFishWebhook(data)
    if _G.WebhookURL == "" or not _G.FilterRarity[data.rarity] then return end
    
    local payload = {
        ["embeds"] = {{
            ["title"] = "🎣 Ikan Tertangkap!",
            ["color"] = 3447003,
            ["fields"] = {
                {["name"] = "Nama", ["value"] = data.fishId, ["inline"] = true},
                {["name"] = "Rarity", ["value"] = data.rarity, ["inline"] = true},
                {["name"] = "Berat", ["value"] = tostring(data.weight) .. " kg", ["inline"] = true}
            }
        }}
    }
    
    local success, response = pcall(function()
        return (http_request or request or syn.request)({
            Url = _G.WebhookURL,
            Method = "POST",
            Headers = {["Content-Type"] = "application/json"},
            Body = HttpService:JSONEncode(payload)
        })
    end)
    
    if not success then warn("Webhook Error: " .. tostring(response)) end
end

-- [[ UI ]]
local WindUI = loadstring(game:HttpGet("https://raw.githubusercontent.com/Footagesus/WindUI/main/dist/main.lua"))()
local Window = WindUI:CreateWindow({Title = "DapzX Atomic | Fishzar v3.3", Icon = "solar:atom-bold", Size = UDim2.fromOffset(500, 400)})

-- TAB: FISHING
local FTab = Window:Tab({Title = "Fishing", Icon = "solar:fishing-rod-bold"})
FTab:Section({Title = "Auto Farm"}):Toggle({Title = "Enable Auto Farm", Callback = function(s) _G.FarmingActive = s end})
FTab:Section({Title = "Auto Sell"}):Toggle({Title = "Auto Sell Semua Ikan", Callback = function(s) _G.AutoSellActive = s end})

-- TAB: INTEGRATION (WEBHOOK & FILTER)
local ITab = Window:Tab({Title = "Integration", Icon = "solar:settings-bold"})
ITab:Section({Title = "Webhook URL"}):Input({Title = "URL", Callback = function(v) _G.WebhookURL = v end})
local FilterSec = ITab:Section({Title = "Filter Rarity (Notif)"})
for _, r in pairs({"Common", "Uncommon", "Rare", "Epic", "Legendary", "Secret"}) do
    FilterSec:Toggle({Title = r, Callback = function(s) _G.FilterRarity[r] = s end})
end

-- [[ MAIN LOOP (FIXED BENGONG) ]]
task.spawn(function()
    local FishingSystem = ReplicatedStorage:WaitForChild("FishingSystem")
    while task.wait(1) do
        if _G.FarmingActive then
            local tool = LocalPlayer.Character:FindFirstChildWhichIsA("Tool")
            if tool and tool:FindFirstChild("Handle") then
                local root = LocalPlayer.Character.HumanoidRootPart
                local castPos = root.Position + (root.CFrame.LookVector * 15)
                
                -- Cast
                FishingSystem.CastReplication:FireServer(castPos, root.Position, tool.Name, 99.5)
                task.wait(3) -- Tunggu lempar
                
                -- Tarik
                FishingSystem.FishGiver:FireServer({["hookPosition"] = castPos})
                task.wait(1)
                
                -- Cek Ikan & Webhook
                for _, item in pairs(LocalPlayer.Backpack:GetChildren()) do
                    if item:IsA("Tool") and item:GetAttribute("rarity") then
                        SendFishWebhook({
                            fishId = item:GetAttribute("fishId") or "Unknown",
                            weight = item:GetAttribute("weight") or 0,
                            rarity = item:GetAttribute("rarity")
                        })
                    end
                end
                
                FishingSystem.CleanupCast:FireServer()
            end
        end
    end
end)

-- [[ AUTO SELL LOOP (SIMPLE) ]]
task.spawn(function()
    while task.wait(10) do
        if _G.AutoSellActive then
            local sellEvent = ReplicatedStorage:FindFirstChild("FishingSystem") and ReplicatedStorage.FishingSystem:FindFirstChild("SellFish")
            if sellEvent then
                local inv = {}
                for _, item in pairs(LocalPlayer.Backpack:GetChildren()) do
                    if item:IsA("Tool") then table.insert(inv, item) end
                end
                if #inv > 0 then sellEvent:FireServer("SellAllBatch", inv) end
            end
        end
    end
end)
