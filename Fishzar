-- 2. LOADING & KEY UI
-- ============================================================================
local function StartSystem()
    local Screen = Instance.new("ScreenGui", game.CoreGui)
    local Main = Instance.new("Frame", Screen)
    Main.Size = UDim2.fromOffset(400, 300)
    Main.Position = UDim2.new(0.5, -200, 0.5, -150)
    Main.BackgroundColor3 = Color3.fromRGB(15, 15, 15)
    Instance.new("UICorner", Main)

    local Logo = Instance.new("ImageLabel", Main)
    Logo.Size = UDim2.fromOffset(100, 100)
    Logo.Position = UDim2.new(0.5, -50, 0.1, 0)
    Logo.Image = "rbxassetid://88673887911141"
    Logo.BackgroundTransparency = 1

    local Title = Instance.new("TextLabel", Main)
    Title.Text = "FLOW HUB | KEY SYSTEM"
    Title.Position = UDim2.new(0, 0, 0.45, 0)
    Title.Size = UDim2.new(1, 0, 0, 30)
    Title.TextColor3 = Color3.new(1,1,1)
    Title.Font = Enum.Font.GothamBold
    Title.BackgroundTransparency = 1

    local Input = Instance.new("TextBox", Main)
    Input.Size = UDim2.new(0.8, 0, 0, 40)
    Input.Position = UDim2.new(0.1, 0, 0.6, 0)
    Input.PlaceholderText = "Enter Key Here..."
    Input.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
    Input.TextColor3 = Color3.new(1,1,1)
    Instance.new("UICorner", Input)

    local btn = Instance.new("TextButton", Main)
    btn.Size = UDim2.new(0.8, 0, 0, 40)
    btn.Position = UDim2.new(0.1, 0, 0.8, 0)
    btn.Text = "LOGIN"
    btn.BackgroundColor3 = Color3.fromRGB(0, 180, 216)
    btn.TextColor3 = Color3.new(1,1,1)
    Instance.new("UICorner", btn)

    -- Auto login if key exists
    local saved = ReadKey()
    if table.find(ValidKeys, saved) then
        Screen:Destroy()
        return true
    end

    btn.MouseButton1Click:Connect(function()
        local entered = Input.Text
        if table.find(ValidKeys, entered) then
            SaveKey(entered)
            Screen:Destroy()
        else
            LocalPlayer:Kick("Invalid Key! Case Sensitive.")
        end
    end)
    
    repeat task.wait() until not Screen.Parent
    return true
end

