    execName = (identifyexecutor and identifyexecutor())
        or (getexecutorname and getexecutorname())
        or "Unknown"
end)

-- Unified HTTP request handler with fallbacks
local request = (syn and syn.request)
    or (http and http.request)
    or (http_request)
    or (request)
    or function(t)
        return HttpService:RequestAsync(t)
    end

local function safeRequest(data)
    local ok, err = pcall(request, data)
    if not ok then
        warn("[Flow Studio | Webhook] Error: " .. tostring(err))
    end
end

