MainTab:Section({Title = "© 2026 DapzX Team. All Rights Reserved."})
MainTab:Section({Title = "Hak Cipta: Kode ini dilindungi undang-undang. Dilarang keras memperjualbelikan, mendekompilasi, atau mendistribusikan ulang tanpa izin tertulis dari DapzX Team. Pelanggaran akan berakibat pada pemblokiran akses."})
MainTab:Button({Title = "Copy Discord Server", Callback = function() setclipboard("https://discord.gg/getsades") end})
MainTab:Section({Title = "📢 Changelog v17.0.0"})
MainTab:Section({Title = "• MAJOR FIX: Seluruh tab yang hilang (Teleport/Utilities) telah dipulihkan.\n• FIXED: Webhook Rarity kini menyertakan filter lengkap & log real-time.\n• ADDED: Anti-AFK (VirtualUser bypass).\n• FIXED: Streamer Mode (Menghapus BillboardGui secara paksa).\n• FIXED: Anti-Staff & Anti-Drown logic.\n• OPTIMIZED: UI Persistent (Tombol tidak hilang saat di-minimize).", TextSize = 12})

-- [[ TAB PLAYER ]]
local PlayerTab = Window:Tab({Title = "Player", Icon = "solar:user-bold"})
PlayerTab:Toggle({Title = "Walk on Water", Callback = function(s) _G.Config.WalkWater = s end})
PlayerTab:Toggle({Title = "Anti AFK", Callback = function(s) _G.Config.AntiAFK = s end})
PlayerTab:Toggle({Title = "Anti Drown", Callback = function(s) _G.Config.Drown = s end})
PlayerTab:Toggle({Title = "Auto Equip Rod", Callback = function(s) _G.Config.AutoEquip = s end})

-- [[ TAB FISHING ]]
local FTab = Window:Tab({Title = "Fishing", Icon = "solar:fishing-rod-bold"})
FTab:Toggle({Title = "Auto Farm", Callback = function(s) _G.Config.Farming = s end})
FTab:Input({Title = "Settings Delay (Detik)", Placeholder = "3.0", Callback = function(v) _G.Config.Delay = tonumber(v) or 3 end})

-- [[ TAB SHOP ]]
local ShopTab = Window:Tab({Title = "Shop", Icon = "solar:bag-bold"})
ShopTab:Toggle({Title = "Auto Sell", Callback = function(s) _G.Config.AutoSell = s end})

-- [[ TAB TELEPORT ]]
local TTab = Window:Tab({Title = "Teleport", Icon = "solar:map-point-wave-bold"})
local Islands = {["Nelayan"]=Vector3.new(-34,14,256), ["Aquarist"]=Vector3.new(-2032,13,-833), ["Crystaliz"]=Vector3.new(203,13,-2614), ["Megalodon"]=Vector3.new(3125,9,-1713)}
for n,p in pairs(Islands) do TTab:Button({Title=n, Callback=function() if LocalPlayer.Character then LocalPlayer.Character.HumanoidRootPart.CFrame = CFrame.new(p) end end}) end

-- [[ TAB UTILITIES ]]
local UTab = Window:Tab({Title = "Utilities", Icon = "solar:shield-keyhole-bold"})
UTab:Toggle({Title = "Streamer Mode", Callback = function(s) _G.Config.Streamer = s end})
UTab:Toggle({Title = "Anti Staff", Callback = function(s) _G.Config.AntiStaff = s end})
local PingL = UTab:Section({Title = "Ping: Loading..."})
local FPSL = UTab:Section({Title = "FPS: Loading..."})

-- [[ TAB PERFORMANCE ]]
local PTab = Window:Tab({Title = "Performance", Icon = "solar:bolt-bold"})
PTab:Button({Title = "FPS Booster", Callback = function() for _,v in pairs(workspace:GetDescendants()) do if v:IsA("Decal") or v:IsA("Texture") then v:Destroy() end end end})

-- [[ TAB INTEGRATION ]]
local ITab = Window:Tab({Title = "Integration", Icon = "solar:settings-bold"})
ITab:Input({Title = "Webhook URL", Callback = function(v) _G.Config.Webhook = v end})
local RSec = ITab:Section({Title = "Rarity Filter"})
for r, _ in pairs(_G.RarityFilter) do
    RSec:Toggle({Title = r, Value = true, Callback = function(s) _G.RarityFilter[r] = s end})
end

-- [[ LOOPS & LOGIC ]]
-- Anti AFK
LocalPlayer.Idled:Connect(function() VirtualUser:CaptureController(); VirtualUser:ClickButton2(Vector2.new()) end)

-- Webhook
LocalPlayer.Backpack.ChildAdded:Connect(function(i)
    if i:IsA("Tool") and _G.Config.Webhook ~= "" then
        task.wait(0.5)
        local r = i:GetAttribute("rarity") or "Common"
        if _G.RarityFilter[r] then
            local data = {["embeds"]={{["title"]="🎣 Ikan Tertangkap!", ["fields"]={{["name"]="Nama",["value"]=i.Name}, {["name"]="Rarity",["value"]=r}}}}}
            pcall(function() (http_request or request)({Url=_G.Config.Webhook, Method="POST", Headers={["Content-Type"]="application/json"}, Body=HttpService:JSONEncode(data)}) end)
        end
    end
end)

-- Main Loop
task.spawn(function()
    while task.wait(1) do
        PingL:SetTitle("Ping: " .. math.floor(game:GetService("Stats").Network.ServerStatsItem["Data Ping"]:GetValue()) .. "ms")
        FPSL:SetTitle("FPS: " .. math.floor(workspace:GetRealTimePhysicsFPS()))
        
        if _G.Config.Streamer then
            for _, p in pairs(Players:GetPlayers()) do
                if p.Character and p.Character:FindFirstChild("Head") then
                    for _, v in pairs(p.Character.Head:GetChildren()) do if v:IsA("BillboardGui") then v.Enabled = false end end
                end
            end
        end
    end
end)

task.spawn(function() -- Fishing Logic
    while true do
        task.wait(0.5)
        if _G.Config.Farming and LocalPlayer.Character then
            pcall(function()
                local tool = LocalPlayer.Character:FindFirstChildWhichIsA("Tool")
                if tool then
                    local pos = LocalPlayer.Character.HumanoidRootPart.Position
                    FishingSystem.CastReplication:FireServer(pos + Vector3.new(0,-6,0), pos, tool.Name, 99.5)
                    task.wait(1.5 + _G.Config.Delay)
                    FishingSystem.FishGiver:FireServer({ ["hookPosition"] = pos })
                    task.wait(1.5); FishingSystem.CleanupCast:FireServer()
                end
            end)
        end
    end
end)
